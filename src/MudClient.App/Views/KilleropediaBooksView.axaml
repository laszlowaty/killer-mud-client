<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:models="using:MudClient.App.Models"
             xmlns:b="using:MudClient.App.Behaviors"
             x:Class="MudClient.App.Views.KilleropediaBooksView"
             x:DataType="vm:KilleropediaViewModel"
             Classes="killeropedia-page"
             x:Name="Root">
  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
    <Grid Grid.Row="0" ColumnDefinitions="*,160,Auto,Auto" ColumnSpacing="10">
      <TextBox Grid.Column="0"
               Text="{Binding BookSearchText, UpdateSourceTrigger=PropertyChanged}"
               PlaceholderText="Szukaj po księdze, zaklęciu, profesji, miejscu lub vnum..." />
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding AvailableBookClasses}"
                SelectedItem="{Binding SelectedBookClass}" />
      <TextBlock Grid.Column="2"
                 Classes="mud-faint"
                 Text="{Binding FilteredBookCountText}"
                 VerticalAlignment="Center" />
      <Button Grid.Column="3"
              Content="{Binding BookRefreshButtonText}"
              Command="{Binding RefreshBooksCommand}"
              IsVisible="{Binding IsBookRefreshButtonVisible}"
              IsEnabled="{Binding IsBookRefreshEnabled}"
              Padding="14,6"
              ToolTip.Tip="Deweloperskie odtworzenie katalogu przez komendy booklist" />
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
      <TextBlock Grid.Column="0"
                 Classes="mud-faint"
                 Text="{Binding BookRefreshStatus}"
                 TextTrimming="CharacterEllipsis" />
      <TextBlock Grid.Column="1"
                 Classes="mud-faint"
                 Text="{Binding BooksGeneratedText}" />
    </Grid>

    <Border Grid.Row="2"
            Classes="mud-section"
            Padding="18"
            IsVisible="{Binding HasNoBooks}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <TextBlock Classes="mud-heading-lg" Text="Brak katalogu ksiąg" HorizontalAlignment="Center" />
        <TextBlock Classes="mud-muted"
                   Text="Widok wczytuje wygenerowany plik killeropedia-books.json."
                   TextWrapping="Wrap"
                   TextAlignment="Center" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="2"
          ColumnDefinitions="1*,3,2*"
          IsVisible="{Binding HasBooks}">
      <Border Grid.Column="0" Classes="mud-inset killeropedia-left-page" Padding="12">
        <ListBox ItemsSource="{Binding FilteredBooks}"
                 SelectedItem="{Binding SelectedBook}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:BookEntry">
              <Border Padding="10,7" Margin="0,1" CornerRadius="3">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Row="0" Grid.Column="0"
                             b:SearchHighlight.Text="{Binding Name}"
                             b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).BookSearchText}"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Classes="mud-faint"
                             Text="{Binding Vnum, StringFormat='vnum {0}'}" />
                  <TextBlock Grid.Row="1" Grid.Column="0"
                             Classes="mud-faint"
                             b:SearchHighlight.Text="{Binding ClassesText}"
                             b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).BookSearchText}"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Row="1" Grid.Column="1"
                             Classes="mud-faint"
                             Text="{Binding SpellCountText}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <GridSplitter Grid.Column="1" ResizeDirection="Columns" />

      <Border Grid.Column="2" Classes="mud-section killeropedia-right-page" Padding="22">
        <ScrollViewer Classes="killeropedia-content-scroll"
                      b:SearchAutoScroll.Terms="{Binding BookSearchText}"
                      b:SearchAutoScroll.Context="{Binding SelectedBook}">
          <StackPanel Spacing="12" DataContext="{Binding SelectedBook}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock Grid.Column="0" Classes="mud-heading-lg"
                         b:SearchHighlight.Text="{Binding Name}"
                         b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).BookSearchText}" />
              <TextBlock Grid.Column="1"
                         Classes="mud-faint"
                         Text="{Binding Vnum, StringFormat='Vnum: {0}'}"
                         VerticalAlignment="Center" />
            </Grid>

            <Border Classes="mud-inset" Padding="10">
              <StackPanel Spacing="4">
                <TextBlock Classes="mud-heading" Text="PROFESJE" />
                <TextBlock b:SearchHighlight.Text="{Binding ClassesText}"
                           b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).BookSearchText}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <TextBlock Classes="mud-heading" Text="ZAKLĘCIA" />
            <ItemsControl ItemsSource="{Binding Spells}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="mud-inset" Padding="9,5" Margin="0,0,6,6">
                    <TextBlock b:SearchHighlight.Text="{Binding}"
                               b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).BookSearchText}" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Classes="mud-heading" Text="WYSTĘPOWANIE" />
            <TextBlock Classes="mud-faint"
                       Text="Brak informacji o miejscu ładowania."
                       IsVisible="{Binding !LoadLocations.Count}" />
            <ItemsControl ItemsSource="{Binding LoadLocations}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="mud-inset" Padding="9,6" Margin="0,1">
                    <TextBlock b:SearchHighlight.Text="{Binding}"
                               b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).BookSearchText}"
                               TextWrapping="Wrap" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>

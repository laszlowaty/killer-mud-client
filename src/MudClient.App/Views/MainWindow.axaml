<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:MudClient.App.Controls"
        xmlns:views="using:MudClient.App.Views"
        xmlns:vm="using:MudClient.App.ViewModels"
        xmlns:models="using:MudClient.App.Models"
        xmlns:docking="using:MudClient.App.Docking"
        xmlns:dock="using:Dock.Avalonia.Controls"
        x:Class="MudClient.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Icon="/Assets/killer.ico"
        Title="KillerMUD Klient"
         Width="1400"
         Height="900"
         MinWidth="1024"
         MinHeight="680"
         WindowState="Maximized"
        PointerPressed="Window_OnPointerPressed">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ========================================================================
         Row 0: Top bar – 4 sections
         ======================================================================== -->
    <Border Grid.Row="0" Classes="mud-bar-top">
      <StackPanel Spacing="8">

        <!-- Row A: logo + area/profile chips (left), connection + status (right) -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="⚔" FontSize="20" Foreground="{StaticResource MudBrushGoldBright}" VerticalAlignment="Center" />
            <TextBlock Classes="mud-heading-lg" Text="MudClient" VerticalAlignment="Center" />
            <Border Background="{StaticResource MudBrushSlate}"
                    CornerRadius="3"
                    Padding="8,3"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding HeaderAreaText}"
                         FontSize="11"
                         MaxWidth="220"
                         TextTrimming="CharacterEllipsis"
                         Foreground="{StaticResource MudBrushParchmentDim}" />
            </Border>
            <Border Background="{StaticResource MudBrushSlate}"
                    CornerRadius="3"
                    Padding="8,3"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsProfileSelected}">
              <TextBlock Text="{Binding ActiveProfileName, StringFormat='Profil: {0}'}"
                         FontSize="11"
                         MaxWidth="160"
                         TextTrimming="CharacterEllipsis"
                         Foreground="{StaticResource MudBrushGoldBright}" />
            </Border>
            <Button Content="Zmień profil"
                    Command="{Binding SwitchProfileCommand}"
                    FontSize="11"
                    Padding="8,3"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Przełączanie profilu jest możliwe po rozłączeniu sesji." />
            <Button Content="{Binding HiddenPanels.Count, StringFormat='Panele ({0})'}"
                    FontSize="11"
                    Padding="8,3"
                    VerticalAlignment="Center"
                    IsVisible="{Binding HiddenPanels.Count}"
                    ToolTip.Tip="Przywróć schowany panel">
              <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedLeft">
                  <ItemsControl ItemsSource="{Binding HiddenPanels}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="docking:PanelTool">
                        <Button Content="{Binding Title}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="10,6" Margin="0,1"
                                Command="{Binding $parent[Window].DataContext.RestorePanelCommand}"
                                CommandParameter="{Binding}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Flyout>
              </Button.Flyout>
            </Button>
            <Button Content="Resetuj UI"
                    Command="{Binding ResetUiCommand}"
                    FontSize="11"
                    Padding="8,3"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Przywraca domyślny układ paneli" />
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBox Text="{Binding Host}" PlaceholderText="host" MinWidth="120" Width="130" />
            <TextBox Text="{Binding Port}" PlaceholderText="port" MinWidth="55" Width="60" />
            <Button Content="Połącz" Command="{Binding ConnectCommand}" Padding="12,6" />
            <Button Classes="mud-danger" Content="Rozłącz" Command="{Binding DisconnectCommand}" Padding="12,6" />
            <TextBlock Text="{Binding StatusText}"
                       FontWeight="SemiBold"
                       FontSize="12"
                       VerticalAlignment="Center"
                       MaxWidth="140"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource MudBrushEmeraldBright}" />
          </StackPanel>
        </Grid>

        <!-- Row B: vitals (left) + toasts (right, clipped so they never overlap) -->
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      Spacing="14"
                      VerticalAlignment="Center"
                      DataContext="{Binding Vitals}">
            <!-- Hit Points -->
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="HP" FontSize="11" FontWeight="Bold"
                         Foreground="{StaticResource MudBrushCrimsonBright}" VerticalAlignment="Center" />
              <ProgressBar Minimum="0" Maximum="{Binding MaxHitPoints}"
                           Value="{Binding HitPoints}" Width="90" Height="8"
                           Foreground="{StaticResource MudBrushCrimson}"
                           Background="{StaticResource MudBrushVoid}" />
              <TextBlock FontSize="10" VerticalAlignment="Center"
                         Foreground="{StaticResource MudBrushParchmentDim}">
                <Run Text="{Binding HitPoints}" Foreground="{StaticResource MudBrushParchment}" />
                <Run Text="/" Foreground="{StaticResource MudBrushParchmentFaint}" />
                <Run Text="{Binding MaxHitPoints}" Foreground="{StaticResource MudBrushParchmentFaint}" />
              </TextBlock>
            </StackPanel>

            <!-- Spell Points -->
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="SP" FontSize="11" FontWeight="Bold"
                         Foreground="{StaticResource MudBrushArcaneBlueBright}" VerticalAlignment="Center" />
              <ProgressBar Minimum="0" Maximum="{Binding MaxSpellPoints}"
                           Value="{Binding SpellPoints}" Width="90" Height="8"
                           Foreground="{StaticResource MudBrushArcaneBlue}"
                           Background="{StaticResource MudBrushVoid}" />
              <TextBlock FontSize="10" VerticalAlignment="Center"
                         Foreground="{StaticResource MudBrushParchmentDim}">
                <Run Text="{Binding SpellPoints}" Foreground="{StaticResource MudBrushParchment}" />
                <Run Text="/" Foreground="{StaticResource MudBrushParchmentFaint}" />
                <Run Text="{Binding MaxSpellPoints}" Foreground="{StaticResource MudBrushParchmentFaint}" />
              </TextBlock>
            </StackPanel>

            <!-- Endurance Points -->
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="EP" FontSize="11" FontWeight="Bold"
                         Foreground="{StaticResource MudBrushEmeraldBright}" VerticalAlignment="Center" />
              <ProgressBar Minimum="0" Maximum="{Binding MaxEndurancePoints}"
                           Value="{Binding EndurancePoints}" Width="90" Height="8"
                           Foreground="{StaticResource MudBrushEmerald}"
                           Background="{StaticResource MudBrushVoid}" />
              <TextBlock FontSize="10" VerticalAlignment="Center"
                         Foreground="{StaticResource MudBrushParchmentDim}">
                <Run Text="{Binding EndurancePoints}" Foreground="{StaticResource MudBrushParchment}" />
                <Run Text="/" Foreground="{StaticResource MudBrushParchmentFaint}" />
                <Run Text="{Binding MaxEndurancePoints}" Foreground="{StaticResource MudBrushParchmentFaint}" />
              </TextBlock>
            </StackPanel>
          </StackPanel>

          <!-- Toasts: newest on the left; anything that doesn't fit is clipped, never overlapping -->
          <Border Grid.Column="1" ClipToBounds="True">
            <ItemsControl ItemsSource="{Binding Toasts}" HorizontalAlignment="Right">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:ToastMessage">
                  <Border CornerRadius="3" Padding="6,3"
                          Classes="mud-section"
                          IsVisible="{Binding IsVisible}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="{Binding IconGlyph}" FontSize="11"
                                 Foreground="{Binding ForegroundBrush}" />
                      <TextBlock Text="{Binding Text}" FontSize="11" MaxWidth="260"
                                 ToolTip.Tip="{Binding Text}"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

          <Button Grid.Column="2" Classes="mud-small" Content="✕"
                  Command="{Binding ClearToastsCommand}"
                  ToolTip.Tip="Wyczyść powiadomienia"
                  VerticalAlignment="Center"
                  Padding="6,2"
                  IsVisible="{Binding Toasts.Count}" />
        </Grid>

      </StackPanel>
    </Border>

     <!-- ========================================================================
         Row 1: Main content – 25* (left), 50* (terminal), 25* (right)
         ======================================================================== -->
    <dock:DockControl Grid.Row="1" Layout="{Binding Layout}" Margin="8" />

    <!-- ========================================================================
         Row 2: Footer bar
         ======================================================================== -->
    <Border Grid.Row="2" Classes="mud-bar-bottom" Padding="10,5">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="16">
        <TextBlock Classes="mud-faint" Text="Telnet + ANSI + GMCP  •  MudClient Starter" />
        <TextBlock Classes="mud-faint" Text="{Binding Vitals.Name, StringFormat='Postać: {0}'}" />
        <TextBlock Classes="mud-faint" Text="{Binding StatusText}" />
      </Grid>
    </Border>

    <!-- Profile picker overlay (shown until a profile is chosen) -->
    <Grid Grid.RowSpan="3"
          IsVisible="{Binding !IsProfileSelected}"
          Background="#B0080A0B">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="460"
              Classes="mud-panel"
              BorderBrush="{StaticResource MudBrushGoldBright}"
              BorderThickness="1"
              Padding="24">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="⚔" FontSize="28" Foreground="{StaticResource MudBrushGoldBright}" />
            <StackPanel>
              <TextBlock Classes="mud-heading-lg" Text="WYBIERZ PROFIL" />
              <TextBlock Classes="mud-muted"
                         Text="Profil przechowuje notatki, aliasy, triggery i timery postaci." />
            </StackPanel>
          </StackPanel>

          <TextBlock Classes="mud-faint"
                     Text="Dwuklik na profilu łączy od razu."
                     IsVisible="{Binding HasProfiles}" />

          <ListBox x:Name="ProfileListBox"
                   ItemsSource="{Binding AvailableProfiles}"
                   SelectedItem="{Binding SelectedProfileName}"
                   MaxHeight="220"
                   Background="Transparent"
                   IsVisible="{Binding HasProfiles}"
                   DoubleTapped="ProfileList_OnDoubleTapped">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="CornerRadius" Value="6" />
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="🛡"
                             FontSize="16"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource MudBrushGoldBright}" />
                  <TextBlock Text="{Binding}"
                             FontSize="14"
                             VerticalAlignment="Center" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <TextBlock Classes="mud-faint"
                     Text="Brak zapisanych profili — utwórz pierwszy poniżej."
                     IsVisible="{Binding !HasProfiles}" />

          <Button Content="Wybierz profil"
                  Command="{Binding SelectProfileCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="16,7" />

          <Separator />

          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding NewProfileName}"
                     PlaceholderText="Nazwa nowego profilu" />
            <Button Grid.Column="1"
                    Content="Utwórz"
                    Command="{Binding CreateProfileCommand}"
                    Padding="16,7" />
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Startup / fatal error overlay -->
    <Grid Grid.RowSpan="3"
          IsVisible="{Binding HasStartupError}"
          Background="#B0080A0B">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="620"
              MaxWidth="900"
              Classes="mud-panel"
              BorderBrush="{StaticResource MudBrushCrimson}"
              BorderThickness="1"
              Padding="24">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="☠" FontSize="28" Foreground="{StaticResource MudBrushCrimsonBright}" />
            <StackPanel>
              <TextBlock Classes="mud-heading-lg" Text="BŁĄD URUCHAMIANIA" />
              <TextBlock Classes="mud-muted"
                         Text="Aplikacja napotkała problem przy inicjalizacji widoku." />
            </StackPanel>
          </StackPanel>

          <TextBlock Text="{Binding StartupErrorMessage}"
                     FontSize="16"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />

          <Border Classes="mud-section" Background="{StaticResource MudBrushVoid}" Padding="12">
            <TextBlock Text="{Binding StartupErrorDetails}"
                       Classes="mud-faint"
                       TextWrapping="Wrap" />
          </Border>

          <TextBlock Classes="mud-faint"
                     Text="Możesz spróbować ponownie albo zamknąć aplikację i uruchomić ją jeszcze raz." />

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Ponów" Command="{Binding RetryStartupCommand}" Padding="16,7" />
            <Button Content="Zamknij" Classes="mud-danger" Click="Close_OnClick" Padding="16,7" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

  </Grid>
</Window>

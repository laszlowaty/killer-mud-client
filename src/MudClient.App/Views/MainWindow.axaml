<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:MudClient.App.Controls"
        xmlns:views="using:MudClient.App.Views"
        xmlns:vm="using:MudClient.App.ViewModels"
        xmlns:models="using:MudClient.App.Models"
        xmlns:docking="using:MudClient.App.Docking"
        xmlns:dock="using:Dock.Avalonia.Controls"
        x:Class="MudClient.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Icon="/Assets/killer.ico"
        Title="KillerMudClient"
         Width="1400"
         Height="900"
         MinWidth="1024"
         MinHeight="680"
         WindowState="Maximized"
        PointerPressed="Window_OnPointerPressed">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ========================================================================
         Row 0: Top bar – 4 sections
         ======================================================================== -->
    <Border Grid.Row="0" Classes="mud-bar-top">
      <StackPanel Spacing="8">

        <!-- Row A: logo + area/profile chips (left), connection + status (right) -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="⚔" FontSize="20" Foreground="{StaticResource MudBrushGoldBright}" VerticalAlignment="Center" />
            <TextBlock Classes="mud-heading-lg" Text="KillerMudClient" VerticalAlignment="Center" />
            <Border Background="{StaticResource MudBrushSlate}"
                    CornerRadius="3"
                    Padding="8,3"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding HeaderAreaText}"
                         FontSize="11"
                         MaxWidth="220"
                         TextTrimming="CharacterEllipsis"
                         Foreground="{StaticResource MudBrushParchmentDim}" />
            </Border>
            <Border Background="{StaticResource MudBrushSlate}"
                    CornerRadius="3"
                    Padding="8,3"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsProfileSelected}">
              <TextBlock Text="{Binding ActiveProfileName, StringFormat='Konto: {0}'}"
                         FontSize="11"
                         MaxWidth="160"
                         TextTrimming="CharacterEllipsis"
                         Foreground="{StaticResource MudBrushGoldBright}" />
            </Border>
            <Button Content="Zmień konto"
                    Command="{Binding SwitchProfileCommand}"
                    FontSize="11"
                    Padding="8,3"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Przełączanie konta jest możliwe po rozłączeniu sesji." />
            <Button Content="killeropedia"
                    Command="{Binding OpenKilleropediaCommand}"
                    FontSize="11"
                    Padding="10,3"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Otwórz killeropedię" />
            <Button Content="discord"
                    Command="{Binding OpenDiscordCommand}"
                    FontSize="11"
                    Padding="10,3"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Otwórz Discord Killer MUD" />
            <Button Content="Pomoc"
                    Command="{Binding OpenHelpCommand}"
                    FontSize="11"
                    Padding="10,3"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Otwórz pomoc aplikacji" />
            <Button Content="{Binding HiddenPanels.Count, StringFormat='Panele ({0})'}"
                    FontSize="11"
                    Padding="8,3"
                    VerticalAlignment="Center"
                    IsVisible="{Binding HiddenPanels.Count}"
                    ToolTip.Tip="Przywróć schowany panel u góry">
              <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedLeft">
                  <ItemsControl ItemsSource="{Binding HiddenPanels}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="docking:PanelTool">
                        <Button Content="{Binding Title}"
                                FontFamily="{DynamicResource WidgetFontFamilyResource}"
                                FontSize="{DynamicResource WidgetFontSizeResource}"
                                FontWeight="{DynamicResource WidgetFontWeightResource}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="10,6" Margin="0,1"
                                Command="{Binding $parent[Window].DataContext.RestorePanelCommand}"
                                CommandParameter="{Binding}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Flyout>
              </Button.Flyout>
            </Button>
            <Button Content="Układ"
                    FontSize="11"
                    Padding="8,3"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Zapisz lub przywróć układ paneli">
              <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedLeft">
                  <StackPanel Spacing="6" MinWidth="220">
                    <TextBlock Text="Wczytaj układ" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource MudBrushParchmentDim}" />
                    <ItemsControl ItemsSource="{Binding AvailableLayouts}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:LayoutMenuItem">
                          <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                            <Button Grid.Column="0" Content="{Binding Name}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="10,6"
                                    Command="{Binding $parent[Window].DataContext.ApplyLayoutCommand}"
                                    CommandParameter="{Binding Name}" />
                            <Button Grid.Column="1" Classes="mud-danger" Content="✕"
                                    Padding="8,6" Margin="4,0,0,0"
                                    ToolTip.Tip="Usuń układ"
                                    IsVisible="{Binding CanDelete}"
                                    Command="{Binding $parent[Window].DataContext.DeleteLayoutCommand}"
                                    CommandParameter="{Binding Name}" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Height="1" Background="{StaticResource MudBrushSlate}" Margin="0,4" />
                    <TextBlock Text="Zapisz obecny układ" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource MudBrushParchmentDim}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                      <TextBox Grid.Column="0" Text="{Binding NewLayoutName}"
                               PlaceholderText="nazwa układu" FontSize="11" />
                      <Button Grid.Column="1" Content="Zapisz" Padding="10,6"
                              Command="{Binding SaveLayoutCommand}" />
                    </Grid>
                  </StackPanel>
                </Flyout>
              </Button.Flyout>
            </Button>
          </StackPanel>

          <StackPanel x:Name="ConnectionActions"
                      Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="8"
                      VerticalAlignment="Center">
            <Button Content="Połącz" Command="{Binding ConnectCommand}" Padding="12,6" />
            <Button Classes="mud-danger" Content="Rozłącz" Command="{Binding DisconnectCommand}" Padding="12,6" />
            <TextBlock x:Name="IdleTimeIndicator"
                       Text="{Binding IdleTimeText}"
                       FontSize="11"
                       MinWidth="92"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MudBrushParchmentDim}"
                       ToolTip.Tip="Czas od ostatniej komendy wysłanej do MUD-a" />
            <TextBlock Text="{Binding StatusText}"
                       FontWeight="SemiBold"
                       FontSize="12"
                       VerticalAlignment="Center"
                       MaxWidth="140"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource MudBrushEmeraldBright}" />
          </StackPanel>
        </Grid>

        <!-- Available release: persistent until explicitly dismissed. -->
        <Border Classes="mud-section"
                BorderBrush="{StaticResource MudBrushGold}"
                BorderThickness="1"
                CornerRadius="3"
                Padding="8,4"
                IsVisible="{Binding IsUpdateAvailable}">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0"
                       Text="{Binding UpdateNotificationText}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource MudBrushGoldBright}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Content="Pobierz"
                    Command="{Binding OpenUpdateReleaseCommand}"
                    FontSize="11"
                    Padding="8,3" />
            <Button Grid.Column="2"
                    Content="Lista zmian"
                    Command="{Binding OpenChangelogCommand}"
                    FontSize="11"
                    Padding="8,3" />
            <Button Grid.Column="3"
                    Classes="mud-small"
                    Content="✕"
                    Command="{Binding DismissUpdateCommand}"
                    ToolTip.Tip="Ukryj powiadomienie do następnego uruchomienia"
                    Padding="6,2" />
          </Grid>
        </Border>

        <!-- Map and Killeropedia data can be updated independently of the executable. -->
        <Border Classes="mud-section"
                BorderBrush="{StaticResource MudBrushEmerald}"
                BorderThickness="1"
                CornerRadius="3"
                Padding="8,4"
                IsVisible="{Binding IsContentUpdateAvailable}">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0"
                       Text="{Binding ContentUpdateDescription, StringFormat='Dostępna aktualizacja danych: {0}'}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource MudBrushEmeraldBright}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Content="Aktualizuj"
                    Command="{Binding InstallContentUpdateCommand}"
                    FontSize="11"
                    Padding="8,3" />
          </Grid>
        </Border>

        <!-- Row B: toasts (clipped so they never overlap) -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

          <!-- Toasts: newest on the left; anything that doesn't fit is clipped, never overlapping -->
          <Border Grid.Column="0" ClipToBounds="True">
            <ItemsControl ItemsSource="{Binding Toasts}" HorizontalAlignment="Right">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:ToastMessage">
                  <Border CornerRadius="3" Padding="6,3"
                          Classes="mud-section"
                          IsVisible="{Binding IsVisible}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="{Binding IconGlyph}" FontSize="11"
                                 Foreground="{Binding ForegroundBrush}" />
                      <TextBlock Text="{Binding Text}" FontSize="11" MaxWidth="260"
                                 ToolTip.Tip="{Binding Text}"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

          <Button Grid.Column="1" Classes="mud-small" Content="✕"
                  Command="{Binding ClearToastsCommand}"
                  ToolTip.Tip="Wyczyść powiadomienia"
                  VerticalAlignment="Center"
                  Padding="6,2"
                  IsVisible="{Binding Toasts.Count}" />
        </Grid>

      </StackPanel>
    </Border>

     <!-- ========================================================================
         Row 1: Main content – 25* (left), 50* (terminal), 25* (right)
         ======================================================================== -->
    <dock:DockControl x:Name="MainDock" Grid.Row="1" Layout="{Binding Layout}" Margin="8" />

    <!-- ========================================================================
         Row 2: Footer bar
         ======================================================================== -->
    <Border Grid.Row="2" Classes="mud-bar-bottom" Padding="10,5">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="16">
        <TextBlock Classes="mud-faint" Text="Telnet + ANSI + GMCP  •  KillerMudClient" />
        <TextBlock Classes="mud-faint" Text="{Binding Vitals.Name, StringFormat='Postać: {0}'}" />
        <TextBlock Classes="mud-faint" Text="{Binding StatusText}" />
      </Grid>
    </Border>

    <controls:LargeTabbedWidget Grid.RowSpan="3"
                                Title="KILLEROPEDIA"
                                IsBookStyle="True"
                                IsOpen="{Binding IsKilleropediaOpen}">
      <controls:LargeTabbedWidget.TabContent>
        <TabControl Classes="mud-large-widget-tabs killeropedia-book-tabs">
          <TabItem Classes="killeropedia-tab-teachers" Header="Nauczyciele">
            <views:KilleropediaTeachersView
                                            DataContext="{Binding Killeropedia}" />
          </TabItem>
          <TabItem Classes="killeropedia-tab-books" Header="Księgi Magiczne">
            <views:KilleropediaBooksView
                                         DataContext="{Binding Killeropedia}" />
          </TabItem>
          <TabItem Classes="killeropedia-tab-lore" Header="Świat i lore">
            <views:KilleropediaLoreView
                                        DataContext="{Binding Killeropedia}" />
          </TabItem>
          <TabItem Classes="killeropedia-tab-map" Header="Mapa Świata">
            <views:KilleropediaWorldMapView
                                            DataContext="{Binding Killeropedia}" />
          </TabItem>
        </TabControl>
      </controls:LargeTabbedWidget.TabContent>
    </controls:LargeTabbedWidget>

    <controls:LargeTabbedWidget Grid.RowSpan="3"
                                Title="POMOC"
                                IsOpen="{Binding IsHelpOpen}">
      <controls:LargeTabbedWidget.TabContent>
        <TabControl Classes="mud-large-widget-tabs">
          <TabItem Header="Dostępne komendy">
            <ScrollViewer Margin="0,12,0,0">
              <StackPanel Spacing="10" MaxWidth="900" HorizontalAlignment="Left">
                <TextBlock Classes="mud-heading-lg" Text="DOSTĘPNE KOMENDY" />
                <TextBlock Classes="mud-muted"
                           Text="Komendy klienta wpisuj w polu komendy terminala. Wielkość liter nie ma znaczenia."
                           TextWrapping="Wrap" />

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="150,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/idz" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Rozpoczyna marsz do celu wybranego dwuklikiem na mapie albo wznawia przerwaną podróż." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="150,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/idz &lt;cel&gt;" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Rozpoczyna marsz do członka grupy widocznego przez GMCP albo do zapisanej lokacji o podanej nazwie." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="180,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/idz_dodaj &lt;nazwa&gt;" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Zapisuje obecną lokację pod podaną nazwą dla aktywnego konta." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="150,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/stop" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Zatrzymuje trwający autowalk." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="150,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/recast" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Ponownie rzuca wszystkie brakujące czary z listy wymaganych buffów na postać." />
                  </Grid>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </controls:LargeTabbedWidget.TabContent>
    </controls:LargeTabbedWidget>

    <!-- Profile picker overlay (shown until a profile is chosen) -->
    <Grid Grid.RowSpan="3"
          IsVisible="{Binding !IsProfileSelected}"
          Background="#B0080A0B">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="520"
              Classes="mud-panel"
              BorderBrush="{StaticResource MudBrushGoldBright}"
              BorderThickness="1"
              Padding="24">
        <ScrollViewer MaxHeight="620" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <TextBlock Grid.Column="0" Text="⚔" FontSize="28" Foreground="{StaticResource MudBrushGoldBright}" />
            <StackPanel Grid.Column="1">
              <TextBlock Classes="mud-heading-lg" Text="WYBIERZ KONTO" />
              <TextBlock Classes="mud-muted"
                         TextWrapping="Wrap"
                         Text="Konto przechowuje hasło, notatki, aliasy, triggery i timery postaci." />
            </StackPanel>
          </Grid>

          <TextBlock Classes="mud-faint"
                     TextWrapping="Wrap"
                     Text="Dwuklik na koncie łączy od razu."
                     IsVisible="{Binding HasProfiles}" />

          <ListBox x:Name="ProfileListBox"
                   ItemsSource="{Binding AvailableProfiles}"
                   SelectedItem="{Binding SelectedProfileName}"
                   MaxHeight="120"
                   Background="Transparent"
                   IsVisible="{Binding HasProfiles}"
                   DoubleTapped="ProfileList_OnDoubleTapped">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="CornerRadius" Value="6" />
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                  <TextBlock Grid.Column="0"
                             Text="🛡"
                             FontSize="16"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource MudBrushGoldBright}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding}"
                             FontSize="14"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="2"
                          Content="🗑"
                          FontSize="12"
                          Padding="6,2"
                          VerticalAlignment="Center"
                          Click="DeleteProfile_OnClick"
                          ToolTip.Tip="Usuń konto (bezpowrotnie kasuje plik konta)" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <TextBlock Classes="mud-faint"
                     TextWrapping="Wrap"
                     Text="Brak zapisanych kont — utwórz pierwsze poniżej."
                     IsVisible="{Binding !HasProfiles}" />

          <StackPanel x:Name="ProfileServerFields"
                      Spacing="6"
                      IsVisible="{Binding HasProfiles}">
            <TextBlock Text="Ustawienia wybranego konta"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource MudBrushParchmentDim}" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <TextBox Grid.Column="0"
                       Text="{Binding SelectedProfileLogin}"
                       PlaceholderText="Login MUD"
                       KeyDown="SelectProfileField_OnKeyDown" />
              <TextBox Grid.Column="1"
                       Text="{Binding SelectedProfilePassword}"
                       PasswordChar="●"
                       PlaceholderText="Nowe hasło (opcjonalnie)"
                       KeyDown="SelectProfileField_OnKeyDown"
                       ToolTip.Tip="Puste pole zachowuje zapisane hasło. Hasło jest szyfrowane na dysku." />
            </Grid>
            <Grid ColumnDefinitions="*,110" ColumnSpacing="8">
              <TextBox Grid.Column="0"
                       Text="{Binding Host}"
                       PlaceholderText="host"
                       KeyDown="SelectProfileField_OnKeyDown"
                       ToolTip.Tip="Adres serwera MUD dla wybranego konta" />
              <TextBox Grid.Column="1"
                       Text="{Binding Port}"
                       PlaceholderText="port"
                       KeyDown="SelectProfileField_OnKeyDown"
                       ToolTip.Tip="Port serwera dla wybranego konta (1–65535)" />
            </Grid>
          </StackPanel>

          <Button Content="Wybierz konto"
                  Command="{Binding SelectProfileCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="16,7"
                  IsVisible="{Binding HasProfiles}" />

          <Separator />

          <TextBlock Classes="mud-faint"
                     TextWrapping="Wrap"
                     Text="Nowe konto — jego lokalna nazwa może być inna niż login wysyłany do MUD-a." />

          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding NewProfileName}"
                     PlaceholderText="Nazwa konta w aplikacji"
                     KeyDown="CreateProfileField_OnKeyDown" />
            <TextBox Grid.Column="1"
                     Text="{Binding NewProfileLogin}"
                     PlaceholderText="Login MUD"
                     KeyDown="CreateProfileField_OnKeyDown"
                     ToolTip.Tip="Puste pole użyje nazwy konta jako loginu." />
          </Grid>

          <Grid x:Name="NewProfileServerFields" ColumnDefinitions="*,110" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding NewProfileHost}"
                     PlaceholderText="host"
                     KeyDown="CreateProfileField_OnKeyDown"
                     ToolTip.Tip="Adres serwera MUD dla nowego konta" />
            <TextBox Grid.Column="1"
                     Text="{Binding NewProfilePort}"
                     PlaceholderText="port"
                     KeyDown="CreateProfileField_OnKeyDown"
                     ToolTip.Tip="Port serwera dla nowego konta (1–65535)" />
          </Grid>

          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding NewProfilePassword}"
                     PasswordChar="●"
                     PlaceholderText="Hasło (zapisywane zaszyfrowane)"
                     KeyDown="CreateProfileField_OnKeyDown" />
            <Button Grid.Column="1"
                    Content="Utwórz"
                    Command="{Binding CreateProfileCommand}"
                    Padding="16,7" />
          </Grid>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Startup / fatal error overlay -->
    <Grid Grid.RowSpan="3"
          IsVisible="{Binding HasStartupError}"
          Background="#B0080A0B">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="620"
              MaxWidth="900"
              Classes="mud-panel"
              BorderBrush="{StaticResource MudBrushCrimson}"
              BorderThickness="1"
              Padding="24">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="☠" FontSize="28" Foreground="{StaticResource MudBrushCrimsonBright}" />
            <StackPanel>
              <TextBlock Classes="mud-heading-lg" Text="BŁĄD URUCHAMIANIA" />
              <TextBlock Classes="mud-muted"
                         Text="Aplikacja napotkała problem przy inicjalizacji widoku." />
            </StackPanel>
          </StackPanel>

          <TextBlock Text="{Binding StartupErrorMessage}"
                     FontSize="16"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />

          <Border Classes="mud-section" Background="{StaticResource MudBrushVoid}" Padding="12">
            <TextBlock Text="{Binding StartupErrorDetails}"
                       Classes="mud-faint"
                       TextWrapping="Wrap" />
          </Border>

          <TextBlock Classes="mud-faint"
                     Text="Możesz spróbować ponownie albo zamknąć aplikację i uruchomić ją jeszcze raz." />

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Ponów" Command="{Binding RetryStartupCommand}" Padding="16,7" />
            <Button Content="Zamknij" Classes="mud-danger" Click="Close_OnClick" Padding="16,7" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

  </Grid>
</Window>

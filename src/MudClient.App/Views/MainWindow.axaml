<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:MudClient.App.Controls"
        xmlns:views="using:MudClient.App.Views"
        xmlns:vm="using:MudClient.App.ViewModels"
        xmlns:models="using:MudClient.App.Models"
        xmlns:docking="using:MudClient.App.Docking"
        xmlns:dock="using:Dock.Avalonia.Controls"
        x:Class="MudClient.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Icon="/Assets/killer.ico"
        Title="KillerMudClient"
         Width="1400"
         Height="900"
         MinWidth="1024"
         MinHeight="680"
         WindowState="Maximized"
        PointerPressed="Window_OnPointerPressed">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- A single calm command row. Frequent session actions stay visible; account,
         help and layout management live in the overflow menu. -->
    <Border x:Name="MainTopBar" Grid.Row="0" Classes="mud-bar-top">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="⚔"
                     FontSize="16"
                     Foreground="{StaticResource MudBrushGold}"
                     VerticalAlignment="Center" />
          <TextBlock Classes="mud-brand" Text="KillerMudClient" VerticalAlignment="Center" />
          <Border Classes="mud-status-chip" IsVisible="{Binding IsProfileSelected}">
            <TextBlock Text="{Binding ActiveProfileName}"
                       MaxWidth="140"
                       TextTrimming="CharacterEllipsis" />
          </Border>
          <TextBlock Text="{Binding HeaderAreaText}"
                     Classes="mud-caption"
                     MaxWidth="220"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Column="1">
          <Button x:Name="TopKilleropediaButton"
                  Content="Killeropedia"
                  Command="{Binding OpenKilleropediaCommand}"
                  Classes="mud-small"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Otwórz Killeropedię" />

          <StackPanel Orientation="Horizontal"
                      Spacing="6"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">
            <Button x:Name="ApplicationUpdateButton"
                  Classes="mud-notice"
                  Content="Nowa wersja"
                  IsVisible="{Binding IsUpdateAvailable}">
              <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedRight">
                  <StackPanel Spacing="8" Width="320">
                    <TextBlock Classes="mud-section-title"
                               Text="Aktualizacja aplikacji" />
                    <TextBlock Text="{Binding UpdateNotificationText}"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                      <Button Content="Pobierz"
                              Command="{Binding OpenUpdateReleaseCommand}"
                              Classes="mud-small" />
                      <Button Content="Lista zmian"
                              Command="{Binding OpenChangelogCommand}"
                              Classes="mud-small" />
                      <Button Content="Ukryj"
                              Command="{Binding DismissUpdateCommand}"
                              Classes="mud-small" />
                    </StackPanel>
                  </StackPanel>
                </Flyout>
              </Button.Flyout>
            </Button>

            <Button x:Name="ContentUpdateButton"
                    Classes="mud-notice mud-notice-success"
                    Content="Nowe dane"
                    IsVisible="{Binding IsContentUpdateAvailable}">
              <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedRight">
                  <StackPanel Spacing="8" Width="340">
                    <TextBlock Classes="mud-section-title"
                               Text="Aktualizacja danych gry" />
                    <TextBlock Text="{Binding ContentUpdateDescription}"
                               TextWrapping="Wrap" />
                    <Button Content="Aktualizuj"
                            Command="{Binding InstallContentUpdateCommand}"
                            Classes="mud-small"
                            HorizontalAlignment="Right" />
                  </StackPanel>
                </Flyout>
              </Button.Flyout>
            </Button>
          </StackPanel>
        </Grid>

        <StackPanel x:Name="ConnectionActions"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="7"
                    VerticalAlignment="Center">
          <TextBlock x:Name="IdleTimeIndicator"
                     Text="{Binding IdleTimeText}"
                     Classes="mud-caption"
                     MinWidth="86"
                     VerticalAlignment="Center"
                     ToolTip.Tip="Czas od ostatniej komendy wysłanej do MUD-a" />
          <TextBlock Text="{Binding StatusText}"
                     Classes="mud-connection-status"
                     VerticalAlignment="Center"
                     MaxWidth="120"
                     TextTrimming="CharacterEllipsis" />
          <Button Content="Połącz"
                  Command="{Binding ConnectCommand}"
                  IsVisible="{Binding !IsConnected}"
                  Classes="mud-small" />
          <Button Classes="mud-danger mud-small"
                  Content="Rozłącz"
                  Command="{Binding DisconnectCommand}"
                  IsVisible="{Binding IsConnected}" />
          <Button x:Name="MoreActionsButton"
                  Content="Więcej  ⋯"
                  Classes="mud-small"
                  ToolTip.Tip="Konto, narzędzia i układ">
            <Button.Flyout>
              <Flyout Placement="BottomEdgeAlignedRight">
                <StackPanel Spacing="4" MinWidth="220">
                  <Button Content="Zmień konto"
                          Command="{Binding SwitchProfileCommand}"
                          HorizontalContentAlignment="Left"
                          Classes="mud-menu-action"
                          ToolTip.Tip="Przełączanie konta jest możliwe po rozłączeniu sesji." />
                  <Button Content="Discord"
                          Command="{Binding OpenDiscordCommand}"
                          HorizontalContentAlignment="Left"
                          Classes="mud-menu-action" />
                  <Button Content="Pomoc"
                          Command="{Binding OpenHelpCommand}"
                          HorizontalContentAlignment="Left"
                          Classes="mud-menu-action" />
                  <Separator Margin="0,3" />
                  <Button Content="{Binding HiddenPanels.Count, StringFormat='Przywróć panele ({0})'}"
                          IsVisible="{Binding HiddenPanels.Count}"
                          HorizontalContentAlignment="Left"
                          Classes="mud-menu-action">
                    <Button.Flyout>
                      <Flyout Placement="LeftEdgeAlignedTop">
                        <ItemsControl ItemsSource="{Binding HiddenPanels}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="docking:PanelTool">
                              <Button Content="{Binding Title}"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Left"
                                      Classes="mud-menu-action"
                                      Command="{Binding $parent[Window].DataContext.RestorePanelCommand}"
                                      CommandParameter="{Binding}" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Flyout>
                    </Button.Flyout>
                  </Button>
                  <Button Content="Układy paneli"
                          HorizontalContentAlignment="Left"
                          Classes="mud-menu-action">
                    <Button.Flyout>
                      <Flyout Placement="LeftEdgeAlignedTop">
                        <StackPanel Spacing="6" MinWidth="220">
                          <TextBlock Classes="mud-section-title" Text="Wczytaj układ" />
                          <ItemsControl ItemsSource="{Binding AvailableLayouts}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="models:LayoutMenuItem">
                                <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                  <Button Grid.Column="0"
                                          Content="{Binding Name}"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Left"
                                          Classes="mud-menu-action"
                                          Command="{Binding $parent[Window].DataContext.ApplyLayoutCommand}"
                                          CommandParameter="{Binding Name}" />
                                  <Button Grid.Column="1"
                                          Classes="mud-danger mud-small"
                                          Content="✕"
                                          Margin="4,0,0,0"
                                          ToolTip.Tip="Usuń układ"
                                          IsVisible="{Binding CanDelete}"
                                          Command="{Binding $parent[Window].DataContext.DeleteLayoutCommand}"
                                          CommandParameter="{Binding Name}" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <Separator Margin="0,3" />
                          <TextBlock Classes="mud-section-title" Text="Zapisz obecny układ" />
                          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewLayoutName}"
                                     PlaceholderText="Nazwa układu" />
                            <Button Grid.Column="1"
                                    Content="Zapisz"
                                    Classes="mud-small"
                                    Command="{Binding SaveLayoutCommand}" />
                          </Grid>
                        </StackPanel>
                      </Flyout>
                    </Button.Flyout>
                  </Button>
                </StackPanel>
              </Flyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

     <!-- ========================================================================
         Row 1: Main content – 25* (left), 50* (terminal), 25* (right)
         ======================================================================== -->
    <dock:DockControl x:Name="MainDock" Grid.Row="1" Layout="{Binding Layout}" Margin="8" />

    <!-- Transient messages float above the workspace instead of increasing header height. -->
    <StackPanel Grid.Row="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,18,0"
                Spacing="5"
                Panel.ZIndex="100">
      <ItemsControl ItemsSource="{Binding Toasts}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="5" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:ToastMessage">
            <Border Classes="mud-toast"
                    IsVisible="{Binding IsVisible}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="{Binding IconGlyph}"
                           Foreground="{Binding ForegroundBrush}" />
                <TextBlock Text="{Binding Text}"
                           MaxWidth="300"
                           ToolTip.Tip="{Binding Text}"
                           TextTrimming="CharacterEllipsis" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <Button Classes="mud-small"
              Content="Wyczyść"
              Command="{Binding ClearToastsCommand}"
              HorizontalAlignment="Right"
              IsVisible="{Binding Toasts.Count}" />
    </StackPanel>

    <!-- ========================================================================
         Row 2: Footer bar
         ======================================================================== -->
    <Border Grid.Row="2" Classes="mud-bar-bottom" Padding="10,5">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="16">
        <TextBlock Classes="mud-faint" Text="Telnet + ANSI + GMCP  •  KillerMudClient" />
        <TextBlock Classes="mud-faint" Text="{Binding Vitals.Name, StringFormat='Postać: {0}'}" />
        <TextBlock Classes="mud-faint" Text="{Binding StatusText}" />
      </Grid>
    </Border>

    <controls:LargeTabbedWidget Grid.RowSpan="3"
                                Title="Killeropedia"
                                IsBookStyle="True"
                                IsOpen="{Binding IsKilleropediaOpen}">
      <controls:LargeTabbedWidget.TabContent>
        <TabControl Classes="mud-large-widget-tabs killeropedia-book-tabs">
          <TabItem Classes="killeropedia-tab-teachers" Header="Nauczyciele">
            <views:KilleropediaTeachersView
                                            DataContext="{Binding Killeropedia}" />
          </TabItem>
          <TabItem Classes="killeropedia-tab-books" Header="Księgi Magiczne">
            <views:KilleropediaBooksView
                                         DataContext="{Binding Killeropedia}" />
          </TabItem>
          <TabItem Classes="killeropedia-tab-lore" Header="Świat i lore">
            <views:KilleropediaLoreView
                                        DataContext="{Binding Killeropedia}" />
          </TabItem>
          <TabItem Classes="killeropedia-tab-quests" Header="Zadania">
            <views:KilleropediaQuestsView
                                        DataContext="{Binding Killeropedia}" />
          </TabItem>
          <TabItem Classes="killeropedia-tab-map" Header="Mapa Świata">
            <views:KilleropediaWorldMapView
                                            DataContext="{Binding Killeropedia}" />
          </TabItem>
        </TabControl>
      </controls:LargeTabbedWidget.TabContent>
    </controls:LargeTabbedWidget>

    <controls:LargeTabbedWidget Grid.RowSpan="3"
                                Title="Pomoc"
                                IsOpen="{Binding IsHelpOpen}">
      <controls:LargeTabbedWidget.TabContent>
        <TabControl Classes="mud-large-widget-tabs">
          <TabItem Header="Dostępne komendy">
            <ScrollViewer Margin="0,12,0,0">
              <StackPanel Spacing="10" MaxWidth="900" HorizontalAlignment="Left">
                <TextBlock Classes="mud-muted"
                           Text="Komendy klienta wpisuj w polu komendy terminala. Wielkość liter nie ma znaczenia."
                           TextWrapping="Wrap" />

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="150,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/idz" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Rozpoczyna marsz do celu wybranego dwuklikiem na mapie albo wznawia przerwaną podróż." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="150,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/idz &lt;cel&gt;" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Rozpoczyna marsz do członka grupy widocznego przez GMCP albo do zapisanej lokacji o podanej nazwie." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="180,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/idz_dodaj &lt;nazwa&gt;" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Zapisuje obecną lokację pod podaną nazwą dla aktywnego konta." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="150,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/stop" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Zatrzymuje trwający autowalk." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="150,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/recast" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Ponownie rzuca wszystkie brakujące czary z listy wymaganych buffów na postać." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="220,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/map &lt;komenda&gt;" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="W trybie lorda steruje edytorem mapy. Pełna lista komend mapowania znajduje się poniżej. Można też używać prefiksów /mapa i +map." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="220,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="/map show &lt;vnum&gt;" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="Wyszukuje pokój o podanym VNUM-ie, ustawia go jako cel mapy i otwiera widok mapy. Użyj tej komendy, aby szybko przejść do konkretnego pokoju." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="220,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="Komendy mapowania" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="start / stop — rozpoczęcie i zakończenie mapowania; save — zapis zmian; undo / redo — cofanie i ponawianie; cancel — odrzucenie bieżącej sesji; status lub info — stan i informacje o pokoju; check / diff — kontrola i porównanie map; import / export — wymiana mapy z plikiem; discard — odrzucenie mapy roboczej; resolve keep|gmcp — rozwiązanie konfliktu; step &lt;1-20&gt; — krok mapowania; area / reassign — praca z krainą; room — informacje o pokoju; symbol — symbol pokoju; label — etykieta; forget — usunięcie pokoju; special — przejście specjalne." />
                  </Grid>
                </Border>

                <Border Classes="mud-section" Padding="14">
                  <Grid ColumnDefinitions="220,*" ColumnSpacing="18">
                    <TextBlock Grid.Column="0" Text="alias(...) w triggerze/timerze" FontWeight="Bold"
                               Foreground="{StaticResource MudBrushGoldBright}" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Text="W komendzie triggera albo timera wpisz alias(nazwa-aliasu) lub alias(tekst-dopasowany-do-wzorca). Klient uruchomi istniejący alias i wyśle jego rozwinięcie, także wiele komend rozdzielonych nowymi liniami lub separatorem. Przykład: alias(buff)." />
                  </Grid>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </controls:LargeTabbedWidget.TabContent>
    </controls:LargeTabbedWidget>

    <!-- Profile picker overlay (shown until a profile is chosen) -->
    <Grid Grid.RowSpan="3"
          IsVisible="{Binding !IsProfileSelected}"
          Background="#B0080A0B">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="520"
              Classes="mud-panel"
              BorderBrush="{StaticResource MudBrushGoldBright}"
              BorderThickness="1"
              Padding="24">
        <ScrollViewer MaxHeight="620" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <TextBlock Grid.Column="0" Text="⚔" FontSize="28" Foreground="{StaticResource MudBrushGoldBright}" />
            <StackPanel Grid.Column="1">
              <TextBlock Classes="mud-heading-lg" Text="Wybierz konto" />
              <TextBlock Classes="mud-muted"
                         TextWrapping="Wrap"
                         Text="Konto przechowuje hasło, notatki, aliasy, triggery i timery postaci." />
            </StackPanel>
          </Grid>

          <TextBlock Classes="mud-faint"
                     TextWrapping="Wrap"
                     Text="Dwuklik na koncie łączy od razu."
                     IsVisible="{Binding HasProfiles}" />

          <ListBox x:Name="ProfileListBox"
                   ItemsSource="{Binding AvailableProfiles}"
                   SelectedItem="{Binding SelectedProfileName}"
                   MaxHeight="120"
                   Background="Transparent"
                   IsVisible="{Binding HasProfiles}"
                   DoubleTapped="ProfileList_OnDoubleTapped">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="CornerRadius" Value="6" />
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                  <TextBlock Grid.Column="0"
                             Text="🛡"
                             FontSize="16"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource MudBrushGoldBright}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding}"
                             FontSize="14"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="2"
                          Content="🗑"
                          FontSize="12"
                          Padding="6,2"
                          VerticalAlignment="Center"
                          Click="DeleteProfile_OnClick"
                          ToolTip.Tip="Usuń konto (bezpowrotnie kasuje plik konta)" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <TextBlock Classes="mud-faint"
                     TextWrapping="Wrap"
                     Text="Brak zapisanych kont — utwórz pierwsze poniżej."
                     IsVisible="{Binding !HasProfiles}" />

          <StackPanel x:Name="ProfileServerFields"
                      Spacing="6"
                      IsVisible="{Binding HasProfiles}">
            <TextBlock Text="Ustawienia wybranego konta"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource MudBrushParchmentDim}" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <TextBox Grid.Column="0"
                       Text="{Binding SelectedProfileLogin}"
                       PlaceholderText="Login MUD"
                       KeyDown="SelectProfileField_OnKeyDown" />
              <TextBox Grid.Column="1"
                       Text="{Binding SelectedProfilePassword}"
                       PasswordChar="●"
                       PlaceholderText="Nowe hasło (opcjonalnie)"
                       KeyDown="SelectProfileField_OnKeyDown"
                       ToolTip.Tip="Puste pole zachowuje zapisane hasło. Hasło jest szyfrowane na dysku." />
            </Grid>
            <Grid ColumnDefinitions="*,110" ColumnSpacing="8">
              <TextBox Grid.Column="0"
                       Text="{Binding Host}"
                       PlaceholderText="host"
                       KeyDown="SelectProfileField_OnKeyDown"
                       ToolTip.Tip="Adres serwera MUD dla wybranego konta" />
              <TextBox Grid.Column="1"
                       Text="{Binding Port}"
                       PlaceholderText="port"
                       KeyDown="SelectProfileField_OnKeyDown"
                       ToolTip.Tip="Port serwera dla wybranego konta (1–65535)" />
            </Grid>
            <ComboBox ItemsSource="{Binding AvailableEncodings}"
                      SelectedItem="{Binding Encoding}"
                      HorizontalAlignment="Stretch"
                      ToolTip.Tip="Kodowanie tekstu dla wybranego konta (Auto wykrywa UTF-8 lub Windows-1250 automatycznie)" />
          </StackPanel>

          <Button Content="Wybierz konto"
                  Command="{Binding SelectProfileCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="16,7"
                  IsVisible="{Binding HasProfiles}" />

          <Separator />

          <TextBlock Classes="mud-faint"
                     TextWrapping="Wrap"
                     Text="Nowe konto — jego lokalna nazwa może być inna niż login wysyłany do MUD-a." />

          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding NewProfileName}"
                     PlaceholderText="Nazwa konta w aplikacji"
                     KeyDown="CreateProfileField_OnKeyDown" />
            <TextBox Grid.Column="1"
                     Text="{Binding NewProfileLogin}"
                     PlaceholderText="Login MUD"
                     KeyDown="CreateProfileField_OnKeyDown"
                     ToolTip.Tip="Puste pole użyje nazwy konta jako loginu." />
          </Grid>

          <Grid x:Name="NewProfileServerFields" ColumnDefinitions="*,110" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding NewProfileHost}"
                     PlaceholderText="host"
                     KeyDown="CreateProfileField_OnKeyDown"
                     ToolTip.Tip="Adres serwera MUD dla nowego konta" />
            <TextBox Grid.Column="1"
                     Text="{Binding NewProfilePort}"
                     PlaceholderText="port"
                     KeyDown="CreateProfileField_OnKeyDown"
                     ToolTip.Tip="Port serwera dla nowego konta (1–65535)" />
          </Grid>

          <ComboBox ItemsSource="{Binding AvailableEncodings}"
                    SelectedItem="{Binding NewProfileEncoding}"
                    HorizontalAlignment="Stretch"
                    ToolTip.Tip="Kodowanie tekstu dla nowego konta (Auto wykrywa UTF-8 lub Windows-1250 automatycznie)" />

          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding NewProfilePassword}"
                     PasswordChar="●"
                     PlaceholderText="Hasło (zapisywane zaszyfrowane)"
                     KeyDown="CreateProfileField_OnKeyDown" />
            <Button Grid.Column="1"
                    Content="Utwórz"
                    Command="{Binding CreateProfileCommand}"
                    Padding="16,7" />
          </Grid>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Startup / fatal error overlay -->
    <Grid Grid.RowSpan="3"
          IsVisible="{Binding HasStartupError}"
          Background="#B0080A0B">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="620"
              MaxWidth="900"
              Classes="mud-panel"
              BorderBrush="{StaticResource MudBrushCrimson}"
              BorderThickness="1"
              Padding="24">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="☠" FontSize="28" Foreground="{StaticResource MudBrushCrimsonBright}" />
            <StackPanel>
              <TextBlock Classes="mud-heading-lg" Text="Błąd uruchamiania" />
              <TextBlock Classes="mud-muted"
                         Text="Aplikacja napotkała problem przy inicjalizacji widoku." />
            </StackPanel>
          </StackPanel>

          <TextBlock Text="{Binding StartupErrorMessage}"
                     FontSize="16"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />

          <Border Classes="mud-section" Background="{StaticResource MudBrushVoid}" Padding="12">
            <TextBlock Text="{Binding StartupErrorDetails}"
                       Classes="mud-faint"
                       TextWrapping="Wrap" />
          </Border>

          <TextBlock Classes="mud-faint"
                     Text="Możesz spróbować ponownie albo zamknąć aplikację i uruchomić ją jeszcze raz." />

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Ponów" Command="{Binding RetryStartupCommand}" Padding="16,7" />
            <Button Content="Zamknij" Classes="mud-danger" Click="Close_OnClick" Padding="16,7" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

  </Grid>
</Window>

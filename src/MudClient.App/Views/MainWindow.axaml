<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:MudClient.App.Controls"
        xmlns:views="using:MudClient.App.Views"
        xmlns:vm="using:MudClient.App.ViewModels"
        xmlns:models="using:MudClient.App.Models"
        x:Class="MudClient.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Title="⚔ MudClient"
        Width="1400"
        Height="900"
        MinWidth="1024"
        MinHeight="680"
        PointerPressed="Window_OnPointerPressed">

  <Window.Resources>
    <!-- Shared card for a single GMCP message (received and sent lists) -->
    <DataTemplate x:Key="GmcpEntryTemplate" x:DataType="vm:GmcpEntryViewModel">
      <Border Classes="mud-section" Padding="8,6" Margin="0,2">
        <StackPanel Spacing="3">
          <Grid ColumnDefinitions="*,Auto">
            <SelectableTextBlock Grid.Column="0"
                                 Text="{Binding Package}"
                                 FontWeight="SemiBold"
                                 FontSize="12"
                                 Foreground="{StaticResource MudBrushArcaneBlueBright}"
                                 TextWrapping="NoWrap" />
            <SelectableTextBlock Grid.Column="1"
                                 Classes="mud-faint"
                                 Text="{Binding ReceivedAt}"
                                 FontSize="10" />
          </Grid>
          <SelectableTextBlock Text="{Binding Json}"
                               Classes="mud-faint"
                               FontFamily="Consolas,Courier New,monospace"
                               FontSize="10"
                               TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ========================================================================
         Row 0: Top bar – 4 sections
         ======================================================================== -->
    <Border Grid.Row="0" Classes="mud-bar-top">
      <StackPanel Spacing="8">

        <!-- Row A: logo + area/profile chips (left), connection + status (right) -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="⚔" FontSize="20" Foreground="{StaticResource MudBrushGoldBright}" VerticalAlignment="Center" />
            <TextBlock Classes="mud-heading-lg" Text="MudClient" VerticalAlignment="Center" />
            <Border Background="{StaticResource MudBrushSlate}"
                    CornerRadius="3"
                    Padding="8,3"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding HeaderAreaText}"
                         FontSize="11"
                         MaxWidth="220"
                         TextTrimming="CharacterEllipsis"
                         Foreground="{StaticResource MudBrushParchmentDim}" />
            </Border>
            <Border Background="{StaticResource MudBrushSlate}"
                    CornerRadius="3"
                    Padding="8,3"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsProfileSelected}">
              <TextBlock Text="{Binding ActiveProfileName, StringFormat='Profil: {0}'}"
                         FontSize="11"
                         MaxWidth="160"
                         TextTrimming="CharacterEllipsis"
                         Foreground="{StaticResource MudBrushGoldBright}" />
            </Border>
            <Button Content="Zmień profil"
                    Command="{Binding SwitchProfileCommand}"
                    FontSize="11"
                    Padding="8,3"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Przełączanie profilu jest możliwe po rozłączeniu sesji." />
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBox Text="{Binding Host}" PlaceholderText="host" MinWidth="120" Width="130" />
            <TextBox Text="{Binding Port}" PlaceholderText="port" MinWidth="55" Width="60" />
            <Button Content="Połącz" Command="{Binding ConnectCommand}" Padding="12,6" />
            <Button Classes="mud-danger" Content="Rozłącz" Command="{Binding DisconnectCommand}" Padding="12,6" />
            <TextBlock Text="{Binding StatusText}"
                       FontWeight="SemiBold"
                       FontSize="12"
                       VerticalAlignment="Center"
                       MaxWidth="140"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource MudBrushEmeraldBright}" />
          </StackPanel>
        </Grid>

        <!-- Row B: vitals (left) + toasts (right, clipped so they never overlap) -->
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      Spacing="14"
                      VerticalAlignment="Center"
                      DataContext="{Binding Vitals}">
            <!-- Hit Points -->
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="HP" FontSize="11" FontWeight="Bold"
                         Foreground="{StaticResource MudBrushCrimsonBright}" VerticalAlignment="Center" />
              <ProgressBar Minimum="0" Maximum="{Binding MaxHitPoints}"
                           Value="{Binding HitPoints}" Width="90" Height="8"
                           Foreground="{StaticResource MudBrushCrimson}"
                           Background="{StaticResource MudBrushVoid}" />
              <TextBlock FontSize="10" VerticalAlignment="Center"
                         Foreground="{StaticResource MudBrushParchmentDim}">
                <Run Text="{Binding HitPoints}" Foreground="{StaticResource MudBrushParchment}" />
                <Run Text="/" Foreground="{StaticResource MudBrushParchmentFaint}" />
                <Run Text="{Binding MaxHitPoints}" Foreground="{StaticResource MudBrushParchmentFaint}" />
              </TextBlock>
            </StackPanel>

            <!-- Spell Points -->
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="SP" FontSize="11" FontWeight="Bold"
                         Foreground="{StaticResource MudBrushArcaneBlueBright}" VerticalAlignment="Center" />
              <ProgressBar Minimum="0" Maximum="{Binding MaxSpellPoints}"
                           Value="{Binding SpellPoints}" Width="90" Height="8"
                           Foreground="{StaticResource MudBrushArcaneBlue}"
                           Background="{StaticResource MudBrushVoid}" />
              <TextBlock FontSize="10" VerticalAlignment="Center"
                         Foreground="{StaticResource MudBrushParchmentDim}">
                <Run Text="{Binding SpellPoints}" Foreground="{StaticResource MudBrushParchment}" />
                <Run Text="/" Foreground="{StaticResource MudBrushParchmentFaint}" />
                <Run Text="{Binding MaxSpellPoints}" Foreground="{StaticResource MudBrushParchmentFaint}" />
              </TextBlock>
            </StackPanel>

            <!-- Endurance Points -->
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="EP" FontSize="11" FontWeight="Bold"
                         Foreground="{StaticResource MudBrushEmeraldBright}" VerticalAlignment="Center" />
              <ProgressBar Minimum="0" Maximum="{Binding MaxEndurancePoints}"
                           Value="{Binding EndurancePoints}" Width="90" Height="8"
                           Foreground="{StaticResource MudBrushEmerald}"
                           Background="{StaticResource MudBrushVoid}" />
              <TextBlock FontSize="10" VerticalAlignment="Center"
                         Foreground="{StaticResource MudBrushParchmentDim}">
                <Run Text="{Binding EndurancePoints}" Foreground="{StaticResource MudBrushParchment}" />
                <Run Text="/" Foreground="{StaticResource MudBrushParchmentFaint}" />
                <Run Text="{Binding MaxEndurancePoints}" Foreground="{StaticResource MudBrushParchmentFaint}" />
              </TextBlock>
            </StackPanel>
          </StackPanel>

          <!-- Toasts: newest on the left; anything that doesn't fit is clipped, never overlapping -->
          <Border Grid.Column="1" ClipToBounds="True">
            <ItemsControl ItemsSource="{Binding Toasts}" HorizontalAlignment="Right">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:ToastMessage">
                  <Border CornerRadius="3" Padding="6,3"
                          Classes="mud-section"
                          IsVisible="{Binding IsVisible}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="{Binding IconGlyph}" FontSize="11"
                                 Foreground="{Binding ForegroundBrush}" />
                      <TextBlock Text="{Binding Text}" FontSize="11" MaxWidth="260"
                                 ToolTip.Tip="{Binding Text}"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

          <Button Grid.Column="2" Classes="mud-small" Content="✕"
                  Command="{Binding ClearToastsCommand}"
                  ToolTip.Tip="Wyczyść powiadomienia"
                  VerticalAlignment="Center"
                  Padding="6,2"
                  IsVisible="{Binding Toasts.Count}" />
        </Grid>

      </StackPanel>
    </Border>

    <!-- ========================================================================
         Row 1: Main content – 38* (map), 35* (terminal), 27*
         ======================================================================== -->
    <Grid Grid.Row="1" ColumnDefinitions="38*,4,35*,4,27*">

      <!-- ============================================
           Col 0 (38*): Map panel
           ============================================ -->
      <Border Grid.Column="0" Classes="mud-panel" Margin="8,8,0,8">
        <views:MapView DataContext="{Binding Map}" />
      </Border>

      <!-- GridSplitter -->
      <GridSplitter Grid.Column="1" ResizeDirection="Columns" />

      <!-- ============================================
           Col 2 (35*): Terminal panel
           ============================================ -->
      <Border Grid.Column="2" Classes="mud-panel" Margin="0,8,0,8">
        <Grid RowDefinitions="Auto,*,Auto,Auto">

          <!-- Log filter tabs (mock buttons via code-behind) -->
          <Border Grid.Row="0" Classes="mud-bar" Padding="6,4">
            <StackPanel Orientation="Horizontal" Spacing="2"
                        x:Name="LogFilterPanel">
              <ToggleButton Classes="mud-chip" Content="Wszystko" IsChecked="True" Click="LogFilter_OnClick" Tag="all" />
              <ToggleButton Classes="mud-chip" Content="Walka" Click="LogFilter_OnClick" Tag="combat" />
              <ToggleButton Classes="mud-chip" Content="Czaty" Click="LogFilter_OnClick" Tag="chat" />
              <ToggleButton Classes="mud-chip" Content="System" Click="LogFilter_OnClick" Tag="system" />
            </StackPanel>
          </Border>

          <!-- MUD output -->
          <controls:MudOutputView Grid.Row="1" x:Name="MudOutput"
                                  OutputFontFamily="{Binding OutputFontFamily}"
                                  OutputFontSize="{Binding OutputFontSize}" />

          <!-- Quick command chips -->
          <ScrollViewer Grid.Row="2"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled"
                        Height="36">
            <ItemsControl ItemsSource="{Binding QuickCommands}" Margin="6,2">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="4" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:QuickCommand">
                  <Button Classes="mud-chip"
                          Content="{Binding Label}"
                          Click="QuickCommandChip_OnClick" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <!-- Command bar -->
          <Border Grid.Row="3" Classes="mud-bar-bottom" Padding="8,6">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0"
                       x:Name="CommandBox"
                       Classes="terminal-input"
                       Text="{Binding CommandText}"
                       PlaceholderText="Wpisz komendę i naciśnij Enter…"
                       KeyDown="CommandBox_OnKeyDown" />
              <Button Grid.Column="1"
                      Content="➤ Wyślij"
                      Padding="20,7"
                      Command="{Binding SendCommandCommand}"
                      Click="SendButton_OnClick" />
            </Grid>
          </Border>

        </Grid>
      </Border>

      <!-- GridSplitter -->
      <GridSplitter Grid.Column="3" ResizeDirection="Columns" />

      <!-- ============================================
           Col 4 (27*): Right sidebar
           ============================================ -->
      <Border Grid.Column="4" Classes="mud-panel" Margin="0,8,8,8">
        <TabControl SelectedIndex="{Binding SelectedRightTab}">

          <!-- ========================================
               Tab 0: Postać (Character)
               ======================================== -->
          <TabItem Header="⚔ Postać">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="12">

                <!-- Character info -->
                <TextBlock Classes="mud-heading" Text="INFORMACJE" />
                <Border Classes="mud-section">
                  <StackPanel Spacing="4" DataContext="{Binding Vitals}">
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock Classes="mud-muted" Text="Imię:" />
                      <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                                 Text="{Binding Name}" FontWeight="SemiBold"
                                 Foreground="{StaticResource MudBrushGoldBright}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock Classes="mud-muted" Text="Poziom:" />
                      <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                                 Text="{Binding Level}" FontWeight="Bold" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock Classes="mud-muted" Text="Płeć:" />
                      <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                                 Text="{Binding SexDisplay}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock Classes="mud-muted" Text="Pozycja:" />
                      <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                                 Text="{Binding PositionDisplay}"
                                 Foreground="{StaticResource MudBrushArcaneBlue}" />
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- Conditions (live from Char.Condition GMCP) -->
                <TextBlock Classes="mud-heading" Text="KONDYCJA" Margin="0,6,0,0" />
                <Border Classes="mud-section" Padding="8,6">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="mud-faint" Text="W pełni sił — brak dolegliwości."
                               IsVisible="{Binding !Conditions.Count}" />
                    <ItemsControl ItemsSource="{Binding Conditions}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                          <Border Background="{StaticResource MudBrushStoneLight}"
                                  BorderBrush="{StaticResource MudBrushCrimson}"
                                  BorderThickness="1"
                                  CornerRadius="3" Padding="7,3" Margin="0,2,4,2">
                            <TextBlock Text="{Binding}" FontSize="11"
                                       Foreground="{StaticResource MudBrushCrimsonBright}" />
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <!-- Effects (live from Char.Affects GMCP) -->
                <TextBlock Classes="mud-heading" Text="EFEKTY" Margin="0,6,0,0" />
                <Border Classes="mud-section" Padding="8,6">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="mud-faint" Text="Brak aktywnych efektów."
                               IsVisible="{Binding !Effects.Count}" />
                    <ItemsControl ItemsSource="{Binding Effects}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:StatusEffect">
                          <Grid>
                            <Border BorderBrush="{StaticResource MudBrushCrimson}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="6,3"
                                    Margin="0,1"
                                    IsVisible="{Binding IsDebuff}">
                              <Grid ColumnDefinitions="Auto,*,Auto"
                                    RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Column="0" Grid.Row="0"
                                           Text="{Binding Icon}" FontSize="12"
                                           Foreground="{StaticResource MudBrushCrimsonBright}"
                                           Margin="0,0,6,0" />
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Name}" FontSize="12"
                                           Foreground="{StaticResource MudBrushCrimsonBright}"
                                           ToolTip.Tip="{Binding Description}" />
                                <TextBlock Grid.Column="2" Grid.Row="0"
                                           Text="{Binding Duration}"
                                           FontSize="11"
                                           Classes="mud-faint"
                                           HorizontalAlignment="Right"
                                           Margin="6,0,0,0"
                                           IsVisible="{Binding HasDuration}" />
                                <TextBlock Grid.Column="1" Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           FontSize="10"
                                           Classes="mud-faint"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding HasDescription}" />
                              </Grid>
                            </Border>
                            <Border BorderBrush="{StaticResource MudBrushEmerald}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="6,3"
                                    Margin="0,1"
                                    IsVisible="{Binding !IsDebuff}">
                              <Grid ColumnDefinitions="Auto,*,Auto"
                                    RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Column="0" Grid.Row="0"
                                           Text="{Binding Icon}" FontSize="12"
                                           Foreground="{StaticResource MudBrushEmeraldBright}"
                                           Margin="0,0,6,0" />
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Name}" FontSize="12"
                                           ToolTip.Tip="{Binding Description}" />
                                <TextBlock Grid.Column="2" Grid.Row="0"
                                           Text="{Binding Duration}"
                                           FontSize="11"
                                           Classes="mud-faint"
                                           HorizontalAlignment="Right"
                                           Margin="6,0,0,0"
                                           IsVisible="{Binding HasDuration}" />
                                <TextBlock Grid.Column="1" Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           FontSize="10"
                                           Classes="mud-faint"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding HasDescription}" />
                              </Grid>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <!-- People in room -->
                <TextBlock Classes="mud-heading" Text="W POKOJU" Margin="0,6,0,0" />
                <Border Classes="mud-section" Padding="8,6">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="mud-faint" Text="Nikogo tu nie ma."
                               IsVisible="{Binding !People.Count}" />
                    <ItemsControl ItemsSource="{Binding People}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:PersonEntry">
                          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,1">
                            <TextBlock Grid.Column="0" Text="•" Classes="mud-muted" Margin="0,0,6,0" />
                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding FightingText}"
                                       FontSize="11"
                                       Foreground="{StaticResource MudBrushCrimsonBright}"
                                       IsVisible="{Binding IsFighting}" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <!-- Group (live from Char.Group GMCP) -->
                <TextBlock Classes="mud-heading" Text="DRUŻYNA" Margin="0,6,0,0" />
                <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                           Text="Brak członków drużyny."
                           IsVisible="{Binding !Group.Count}" />
                <ItemsControl ItemsSource="{Binding Group}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:GroupMember">
                      <Border Classes="mud-section" Padding="6,4" Margin="0,1">
                        <StackPanel Spacing="2">
                          <!-- Row 1: leader marker + name + NPC marker -->
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{Binding LeaderMarker}"
                                       Foreground="{StaticResource MudBrushGoldBright}"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" />
                            <TextBlock Text="{Binding NpcDisplay}"
                                       FontSize="9"
                                       Foreground="{StaticResource MudBrushParchmentDim}" />
                          </StackPanel>
                          <!-- Row 2: HP + MV + MEM -->
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock FontSize="10"
                                       Foreground="{StaticResource MudBrushCrimson}"
                                       Text="{Binding HpDisplay}" />
                            <TextBlock FontSize="10"
                                       Foreground="{StaticResource MudBrushEmerald}"
                                       Text="{Binding MvDisplay}" />
                            <TextBlock FontSize="10"
                                       Foreground="{StaticResource MudBrushArcaneBlueBright}"
                                       Text="{Binding MemDisplay}"
                                       IsVisible="{Binding MemDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                          </StackPanel>
                          <!-- Row 3: position + room -->
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock FontSize="10" Foreground="{StaticResource MudBrushParchmentDim}"
                                       ToolTip.Tip="Pozycja"
                                       Text="{Binding PositionDisplay}" />
                            <TextBlock FontSize="10" Foreground="{StaticResource MudBrushParchmentFaint}"
                                       ToolTip.Tip="Pokój"
                                       Text="{Binding RoomDisplay}" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <!-- ========================================
               Tab 1: Automatyzacja (Automation)
               ======================================== -->
          <TabItem Header="⚙ Automaty">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="12">

                <!-- ===== Timery ===== -->
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="mud-heading" Text="TIMERY" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Classes="mud-badge">
                    <TextBlock Text="{Binding Timers.Count}" />
                  </Border>
                </Grid>

                <Expander Classes="mud-expander"
                          Header="{Binding TimerFormHeader}"
                          IsExpanded="{Binding IsTimerFormExpanded}">
                  <StackPanel Spacing="8" Margin="0,8,0,0">
                    <TextBox Text="{Binding NewTimerName}" PlaceholderText="Nazwa timera…" />

                    <StackPanel Spacing="2">
                      <TextBlock Classes="mud-faint" Text="Interwał powtarzania" />
                      <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                        <TextBox Grid.Column="0" Text="{Binding NewTimerMinutes}"
                                 PlaceholderText="0" InnerRightContent="min" />
                        <TextBox Grid.Column="1" Text="{Binding NewTimerSeconds}"
                                 PlaceholderText="0" InnerRightContent="s" />
                        <TextBox Grid.Column="2" Text="{Binding NewTimerMilliseconds}"
                                 PlaceholderText="0" InnerRightContent="ms" />
                      </Grid>
                    </StackPanel>

                    <StackPanel Spacing="2">
                      <TextBlock Classes="mud-faint" Text="Komendy — jedna w linii, wysyłane w kolejności" />
                      <TextBox Text="{Binding NewTimerCommands}"
                               PlaceholderText="np.&#x0a;rzuc 'leczenie'&#x0a;pij miksture"
                               FontFamily="Consolas,Courier New,monospace"
                               MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                      <Button Grid.Column="0" Content="{Binding TimerFormButtonText}"
                              Command="{Binding AddTimerCommand}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Center" Padding="16,6" />
                      <Button Grid.Column="1" Content="Anuluj"
                              Command="{Binding CancelTimerEditCommand}"
                              IsVisible="{Binding IsEditingTimer}" Padding="16,6" />
                    </Grid>
                  </StackPanel>
                </Expander>

                <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                           Text="Brak timerów. Timer powtarza komendy w nieskończoność, dopóki go nie wyłączysz."
                           IsVisible="{Binding !Timers.Count}" />

                <ItemsControl ItemsSource="{Binding Timers}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:TimerEntry">
                      <Border Classes="mud-section" Padding="10,8" Margin="0,2">
                        <StackPanel Spacing="6">

                          <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                                        VerticalAlignment="Center">
                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                         FontSize="12" VerticalAlignment="Center"
                                         TextTrimming="CharacterEllipsis" />
                              <Border Classes="mud-badge mud-badge-gold">
                                <TextBlock Text="{Binding IntervalText, StringFormat='co {0}'}" />
                              </Border>
                            </StackPanel>

                            <ToggleButton Grid.Column="1" Classes="mud-switch"
                                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                          Content="{Binding StatusText}"
                                          Click="ToggleTimer_OnClick"
                                          ToolTip.Tip="Włącz / wyłącz timer" />

                            <Button Grid.Column="2"
                                    Classes="mud-small"
                                    Content="✎" Padding="6,2"
                                    ToolTip.Tip="Edytuj timer"
                                    Click="EditTimer_OnClick" />

                            <Button Grid.Column="3"
                                    Classes="mud-small mud-danger"
                                    Content="✕" Padding="6,2"
                                    ToolTip.Tip="Usuń timer"
                                    Click="DeleteTimer_OnClick" />
                          </Grid>

                          <Border Classes="mud-inset" Padding="8,5">
                            <TextBlock Text="{Binding CommandsText}"
                                       FontFamily="Consolas,Courier New,monospace"
                                       FontSize="11"
                                       Foreground="{StaticResource MudBrushParchmentDim}"
                                       TextWrapping="Wrap" />
                          </Border>

                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ===== Aliasy i triggery ===== -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                  <TextBlock Classes="mud-heading" Text="ALIASY I TRIGGERY" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Classes="mud-badge">
                    <TextBlock Text="{Binding AutomationRules.Count}" />
                  </Border>
                </Grid>

                <Expander Classes="mud-expander"
                          Header="{Binding RuleFormHeader}"
                          IsExpanded="{Binding IsRuleFormExpanded}">
                  <StackPanel Spacing="8" Margin="0,8,0,0">

                    <StackPanel Spacing="2">
                      <TextBlock Classes="mud-faint" Text="Typ reguły" />
                      <ComboBox ItemsSource="{Binding RuleTypes}"
                                SelectedItem="{Binding NewRuleType}"
                                HorizontalAlignment="Stretch" />
                      <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                                 Text="Alias podmienia komendę, którą wpisujesz. Trigger reaguje na linię z serwera."
                                 IsVisible="{Binding NewRuleIsAlias}" />
                      <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                                 Text="Trigger wysyła akcję, gdy linia z serwera pasuje do wzorca."
                                 IsVisible="{Binding !NewRuleIsAlias}" />
                    </StackPanel>

                    <TextBox Text="{Binding NewRuleName}" PlaceholderText="Nazwa reguły…" />

                    <StackPanel Spacing="2">
                      <TextBlock Classes="mud-faint" Text="Wzorzec (regex .NET)" />
                      <TextBox Text="{Binding NewRulePattern}"
                               PlaceholderText="np. ^zb (.+)$  albo  (\w+) upada na ziemie"
                               FontFamily="Consolas,Courier New,monospace" />
                      <TextBlock Text="{Binding NewRulePatternError}"
                                 Foreground="{StaticResource MudBrushCrimsonBright}"
                                 FontSize="11" TextWrapping="Wrap"
                                 IsVisible="{Binding HasNewRulePatternError}" />
                    </StackPanel>

                    <StackPanel Spacing="2">
                      <TextBlock Classes="mud-faint" Text="Akcja — jedna komenda w linii; możesz użyć grup: $1, $2…" />
                      <TextBox Text="{Binding NewRuleAction}"
                               PlaceholderText="np.&#x0a;rzuc 'leczenie' $1&#x0a;pij miksture"
                               FontFamily="Consolas,Courier New,monospace"
                               MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                      <Button Grid.Column="0" Content="{Binding RuleFormButtonText}"
                              Command="{Binding AddRuleCommand}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Center" Padding="16,6" />
                      <Button Grid.Column="1" Content="Anuluj"
                              Command="{Binding CancelRuleEditCommand}"
                              IsVisible="{Binding IsEditingRule}" Padding="16,6" />
                    </Grid>
                  </StackPanel>
                </Expander>

                <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                           Text="Brak reguł w tym profilu. Dodaj alias (skrót komendy) albo trigger (automatyczna reakcja na tekst z gry)."
                           IsVisible="{Binding !AutomationRules.Count}" />

                <ItemsControl ItemsSource="{Binding AutomationRules}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:AutomationRuleEntry">
                      <Border Classes="mud-section" Padding="10,8" Margin="0,2">
                        <StackPanel Spacing="4">

                          <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="6">
                            <Border Grid.Column="0" Classes="mud-badge mud-badge-gold">
                              <TextBlock Text="{Binding Type}" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                       FontWeight="SemiBold" FontSize="12"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <ToggleButton Grid.Column="2" Classes="mud-switch"
                                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                          Content="{Binding StatusText}"
                                          Click="ToggleRule_OnClick"
                                          ToolTip.Tip="Włącz / wyłącz regułę" />
                            <Button Grid.Column="3"
                                    Classes="mud-small"
                                    Content="✎" Padding="6,2"
                                    ToolTip.Tip="Edytuj regułę"
                                    Click="EditRule_OnClick" />
                            <Button Grid.Column="4"
                                    Classes="mud-small mud-danger"
                                    Content="✕" Padding="6,2"
                                    ToolTip.Tip="Usuń regułę"
                                    Click="DeleteRule_OnClick" />
                          </Grid>

                          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6" RowDefinitions="Auto,Auto" RowSpacing="1">
                            <TextBlock Grid.Row="0" Grid.Column="0" Classes="mud-faint" Text="Wzorzec" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Classes="mud-faint"
                                       FontFamily="Consolas,Courier New,monospace"
                                       Text="{Binding Pattern}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Classes="mud-faint" Text="Akcja" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Classes="mud-faint"
                                       FontFamily="Consolas,Courier New,monospace"
                                       Text="{Binding Action}" TextWrapping="Wrap" />
                          </Grid>

                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <!-- ========================================
               Tab: Autowalk
               ======================================== -->
          <TabItem Header="🧭 Autowalk">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="12">

                <!-- Status -->
                <TextBlock Classes="mud-heading" Text="STATUS" />
                <Border Classes="mud-section" Padding="10,8">
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock Classes="mud-muted" Text="Pozycja:" />
                      <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                                 Text="{Binding Map.CurrentRoomName}"
                                 TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <TextBlock Text="{Binding AutowalkStatusText}"
                               Classes="mud-faint" TextWrapping="Wrap" />
                    <Button Content="■ STOP"
                            Classes="mud-danger"
                            Command="{Binding StopAutowalkCommand}"
                            IsVisible="{Binding IsAutowalking}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" Padding="16,6" />

                    <!-- Temporary target picked by double-clicking the map -->
                    <StackPanel Spacing="6" IsVisible="{Binding HasTemporaryTarget}">
                      <TextBlock Text="{Binding TemporaryTargetDisplay}"
                                 TextWrapping="Wrap" FontSize="12"
                                 Foreground="{StaticResource MudBrushGoldBright}" />
                      <Button Content="⚑ IDŹ DO CELU"
                              Command="{Binding GoToTemporaryTargetCommand}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Center" Padding="16,6" />
                    </StackPanel>
                  </StackPanel>
                </Border>

                <!-- Add location -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                  <TextBlock Classes="mud-heading" Text="LOKACJE" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Classes="mud-badge">
                    <TextBlock Text="{Binding Locations.Count}" />
                  </Border>
                </Grid>

                <Expander Classes="mud-expander" Header="＋ Nowa lokacja" IsExpanded="False">
                  <StackPanel Spacing="8" Margin="0,8,0,0">
                    <TextBox Text="{Binding NewLocationName}"
                             PlaceholderText="Nazwa lokacji, np. plac-arras…" />
                    <Button Content="⚑ Dodaj obecną pozycję"
                            Command="{Binding AddCurrentLocationCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" Padding="16,6"
                            ToolTip.Tip="Zapisuje pokój, w którym teraz stoisz" />
                    <StackPanel Spacing="2">
                      <TextBlock Classes="mud-faint"
                                 Text="…albo podaj numer pomieszczenia (vnum) innej lokacji:" />
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <TextBox Grid.Column="0" Text="{Binding NewLocationVnum}"
                                 PlaceholderText="np. 12477" />
                        <Button Grid.Column="1" Content="Dodaj"
                                Command="{Binding AddLocationCommand}" Padding="16,6" />
                      </Grid>
                    </StackPanel>
                    <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                               Text="Do zapisanej lokacji dojdziesz przyciskiem IDŹ albo komendą /idz &lt;nazwa&gt;. Komenda /stop przerywa marsz." />
                  </StackPanel>
                </Expander>

                <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                           Text="Brak zapisanych lokacji. Dodaj obecną pozycję albo wpisz vnum docelowego pokoju."
                           IsVisible="{Binding !Locations.Count}" />

                <ItemsControl ItemsSource="{Binding Locations}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:AutowalkLocation">
                      <Border Classes="mud-section" Padding="10,8" Margin="0,2">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                          <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                       FontSize="12" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Display}" Classes="mud-faint"
                                       TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                          <Button Grid.Column="1"
                                  Classes="mud-small"
                                  Content="⚑ IDŹ" Padding="8,2"
                                  ToolTip.Tip="Idź do tej lokacji"
                                  Click="GoToLocation_OnClick" />
                          <Button Grid.Column="2"
                                  Classes="mud-small mud-danger"
                                  Content="✕" Padding="6,2"
                                  ToolTip.Tip="Usuń lokację"
                                  Click="DeleteLocation_OnClick" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <!-- ========================================
               Tab 2: Notatki (Notes)
               ======================================== -->
          <TabItem Header="✎ Notatki">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="12">

                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="mud-heading" Text="NOTATKI" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Classes="mud-badge">
                    <TextBlock Text="{Binding Notes.Count}" />
                  </Border>
                </Grid>

                <Expander Classes="mud-expander" Header="＋ Nowa notatka" IsExpanded="False">
                  <StackPanel Spacing="8" Margin="0,8,0,0">
                    <TextBox Text="{Binding NewNoteTitle}" PlaceholderText="Tytuł…" />
                    <TextBox Text="{Binding NewNoteContent}" PlaceholderText="Treść…"
                             MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap" />
                    <Button Content="Dodaj notatkę" Command="{Binding AddNoteCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" Padding="16,6" />
                  </StackPanel>
                </Expander>

                <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                           Text="Brak notatek w tym profilu."
                           IsVisible="{Binding !Notes.Count}" />
                <ItemsControl ItemsSource="{Binding Notes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:NoteEntry">
                      <Border Classes="mud-section" Padding="8" Margin="0,2">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                          <TextBlock Grid.Row="0" Grid.Column="0"
                                     Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" />
                          <Button Grid.Row="0" Grid.Column="1"
                                  Classes="mud-small mud-danger"
                                  Content="✕" Padding="6,2"
                                  Click="DeleteNote_OnClick" />

                          <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                     Classes="mud-muted" FontSize="11"
                                     TextWrapping="Wrap"
                                     Text="{Binding Content}" />

                          <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                                     Classes="mud-faint"
                                     Text="{Binding CreatedAt}" Margin="0,2,0,0" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <!-- ========================================
               Tab 3: GMCP (received + sent sub-tabs)
               ======================================== -->
          <TabItem Header="⇅ GMCP">
            <TabControl Classes="mud-subtabs">

              <TabItem Header="Odebrane">
                <Grid RowDefinitions="Auto,*" Margin="8,4,8,8">
                  <TextBlock Classes="mud-faint" TextWrapping="Wrap" Margin="0,4"
                             Text="Jeszcze nic nie odebrano — połącz się z serwerem."
                             IsVisible="{Binding !GmcpMessages.Count}" />
                  <ScrollViewer Grid.Row="1"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding GmcpMessages}"
                                  ItemTemplate="{StaticResource GmcpEntryTemplate}" />
                  </ScrollViewer>
                </Grid>
              </TabItem>

              <TabItem Header="Wysłane">
                <Grid RowDefinitions="Auto,*" Margin="8,4,8,8">
                  <TextBlock Classes="mud-faint" TextWrapping="Wrap" Margin="0,4"
                             Text="Jeszcze nic nie wysłano."
                             IsVisible="{Binding !SentGmcpMessages.Count}" />
                  <ScrollViewer Grid.Row="1"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SentGmcpMessages}"
                                  ItemTemplate="{StaticResource GmcpEntryTemplate}" />
                  </ScrollViewer>
                </Grid>
              </TabItem>

            </TabControl>
          </TabItem>

          <!-- ========================================
               Tab 4: Ustawienia (system-wide settings)
               ======================================== -->
          <TabItem Header="🛠">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="12">

                <TextBlock Classes="mud-heading" Text="USTAWIENIA SYSTEMOWE" />
                <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                           Text="Wspólne dla wszystkich profili. Zapisywane automatycznie." />

                <TextBlock Classes="mud-heading" Text="TEKST Z MUDA" Margin="0,6,0,0" />
                <Border Classes="mud-section" Padding="10">
                  <StackPanel Spacing="10">

                    <StackPanel Spacing="3">
                      <TextBlock Classes="mud-faint" Text="Czcionka" />
                      <ComboBox ItemsSource="{Binding AvailableFonts}"
                                SelectedItem="{Binding OutputFontFamily}"
                                HorizontalAlignment="Stretch"
                                MaxDropDownHeight="320">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{Binding}" FontFamily="{Binding}" FontSize="13" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="3">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="mud-faint" Text="Rozmiar" />
                        <Border Grid.Column="1" Classes="mud-badge mud-badge-gold">
                          <TextBlock Text="{Binding OutputFontSizeText}" />
                        </Border>
                      </Grid>
                      <Slider Minimum="{Binding MinOutputFontSize}"
                              Maximum="{Binding MaxOutputFontSize}"
                              Value="{Binding OutputFontSize}"
                              TickFrequency="1"
                              IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <StackPanel Spacing="3">
                      <TextBlock Classes="mud-faint" Text="Podgląd" />
                      <Border Classes="mud-inset" Padding="10,8">
                        <TextBlock Text="Strażnik miasta wchodzi z północy.&#x0a;> zabij straznika"
                                   FontFamily="{Binding OutputFontFamily}"
                                   FontSize="{Binding OutputFontSize}"
                                   Foreground="{StaticResource MudBrushParchment}"
                                   TextWrapping="Wrap" />
                      </Border>
                    </StackPanel>

                    <Button Content="Przywróć domyślne"
                            Command="{Binding ResetOutputFontCommand}"
                            Classes="mud-small"
                            HorizontalAlignment="Right" />

                  </StackPanel>
                </Border>

              </StackPanel>
            </ScrollViewer>
          </TabItem>

        </TabControl>
      </Border>

    </Grid>

    <!-- ========================================================================
         Row 2: Footer bar
         ======================================================================== -->
    <Border Grid.Row="2" Classes="mud-bar-bottom" Padding="10,5">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="16">
        <TextBlock Classes="mud-faint" Text="Telnet + ANSI + GMCP  •  MudClient Starter" />
        <TextBlock Classes="mud-faint" Text="{Binding Vitals.Name, StringFormat='Postać: {0}'}" />
        <TextBlock Classes="mud-faint" Text="{Binding StatusText}" />
      </Grid>
    </Border>

    <!-- Profile picker overlay (shown until a profile is chosen) -->
    <Grid Grid.RowSpan="3"
          IsVisible="{Binding !IsProfileSelected}"
          Background="#B0080A0B">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="460"
              Classes="mud-panel"
              BorderBrush="{StaticResource MudBrushGoldBright}"
              BorderThickness="1"
              Padding="24">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="⚔" FontSize="28" Foreground="{StaticResource MudBrushGoldBright}" />
            <StackPanel>
              <TextBlock Classes="mud-heading-lg" Text="WYBIERZ PROFIL" />
              <TextBlock Classes="mud-muted"
                         Text="Profil przechowuje notatki, aliasy, triggery i timery postaci." />
            </StackPanel>
          </StackPanel>

          <TextBlock Classes="mud-faint"
                     Text="Dwuklik na profilu łączy od razu."
                     IsVisible="{Binding HasProfiles}" />

          <ListBox x:Name="ProfileListBox"
                   ItemsSource="{Binding AvailableProfiles}"
                   SelectedItem="{Binding SelectedProfileName}"
                   MaxHeight="220"
                   Background="Transparent"
                   IsVisible="{Binding HasProfiles}"
                   DoubleTapped="ProfileList_OnDoubleTapped">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="CornerRadius" Value="6" />
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="🛡"
                             FontSize="16"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource MudBrushGoldBright}" />
                  <TextBlock Text="{Binding}"
                             FontSize="14"
                             VerticalAlignment="Center" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <TextBlock Classes="mud-faint"
                     Text="Brak zapisanych profili — utwórz pierwszy poniżej."
                     IsVisible="{Binding !HasProfiles}" />

          <Button Content="Wybierz profil"
                  Command="{Binding SelectProfileCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="16,7" />

          <Separator />

          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding NewProfileName}"
                     PlaceholderText="Nazwa nowego profilu" />
            <Button Grid.Column="1"
                    Content="Utwórz"
                    Command="{Binding CreateProfileCommand}"
                    Padding="16,7" />
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Startup / fatal error overlay -->
    <Grid Grid.RowSpan="3"
          IsVisible="{Binding HasStartupError}"
          Background="#B0080A0B">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="620"
              MaxWidth="900"
              Classes="mud-panel"
              BorderBrush="{StaticResource MudBrushCrimson}"
              BorderThickness="1"
              Padding="24">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="☠" FontSize="28" Foreground="{StaticResource MudBrushCrimsonBright}" />
            <StackPanel>
              <TextBlock Classes="mud-heading-lg" Text="BŁĄD URUCHAMIANIA" />
              <TextBlock Classes="mud-muted"
                         Text="Aplikacja napotkała problem przy inicjalizacji widoku." />
            </StackPanel>
          </StackPanel>

          <TextBlock Text="{Binding StartupErrorMessage}"
                     FontSize="16"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />

          <Border Classes="mud-section" Background="{StaticResource MudBrushVoid}" Padding="12">
            <TextBlock Text="{Binding StartupErrorDetails}"
                       Classes="mud-faint"
                       TextWrapping="Wrap" />
          </Border>

          <TextBlock Classes="mud-faint"
                     Text="Możesz spróbować ponownie albo zamknąć aplikację i uruchomić ją jeszcze raz." />

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Ponów" Command="{Binding RetryStartupCommand}" Padding="16,7" />
            <Button Content="Zamknij" Classes="mud-danger" Click="Close_OnClick" Padding="16,7" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

  </Grid>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:models="using:MudClient.App.Models"
             x:Class="MudClient.App.Views.Panels.EffectsPanelView"
             x:DataType="vm:MainWindowViewModel">
  <UserControl.Styles>
    <Style Selector="Border.effect-entry">
      <Setter Property="BorderBrush" Value="{StaticResource MudBrushEmerald}" />
    </Style>
    <Style Selector="Border.effect-entry.debuff">
      <Setter Property="BorderBrush" Value="{StaticResource MudBrushCrimson}" />
    </Style>
    <Style Selector="Border.effect-entry.ending">
      <Setter Property="BorderBrush" Value="{StaticResource MudBrushCrimson}" />
    </Style>
    <Style Selector="TextBlock.effect-icon">
      <Setter Property="Foreground" Value="{StaticResource MudBrushEmeraldBright}" />
    </Style>
    <Style Selector="TextBlock.effect-icon.debuff">
      <Setter Property="Foreground" Value="{StaticResource MudBrushCrimsonBright}" />
    </Style>
    <Style Selector="TextBlock.effect-icon.ending">
      <Setter Property="Foreground" Value="{StaticResource MudBrushCrimsonBright}" />
    </Style>
    <Style Selector="TextBlock.effect-name.debuff">
      <Setter Property="Foreground" Value="{StaticResource MudBrushCrimsonBright}" />
    </Style>
  </UserControl.Styles>
  <!-- Effects (live from Char.Affects GMCP) -->
  <ScrollViewer>
    <StackPanel Spacing="2" Margin="12">
      <TextBlock Classes="mud-faint" Text="Brak aktywnych efektów."
                 IsVisible="{Binding !Effects.Count}" />
      <ItemsControl ItemsSource="{Binding Effects}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:StatusEffect">
            <Border Classes="effect-entry"
                    Classes.debuff="{Binding IsDebuff}"
                    Classes.ending="{Binding Ending}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="6,3"
                    Margin="0,1">
              <Grid ColumnDefinitions="Auto,*,Auto"
                    RowDefinitions="Auto,Auto">
                <TextBlock Grid.Column="0" Grid.Row="0"
                           Classes="effect-icon"
                           Classes.debuff="{Binding IsDebuff}"
                           Classes.ending="{Binding Ending}"
                           Text="{Binding Icon}"
                           Margin="0,0,6,0" />
                <TextBlock Grid.Column="1" Grid.Row="0"
                           Classes="effect-name"
                           Classes.debuff="{Binding IsDebuff}"
                           Text="{Binding Name}"
                           ToolTip.Tip="{Binding Description}" />
                <TextBlock Grid.Column="2" Grid.Row="0"
                           Text="{Binding Duration}"
                           Classes="mud-faint"
                           HorizontalAlignment="Right"
                           Margin="6,0,0,0"
                           IsVisible="{Binding HasDuration}" />
                <TextBlock Grid.Column="1" Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding Description}"
                           Classes="mud-faint"
                           TextTrimming="CharacterEllipsis"
                           IsVisible="{Binding HasDescription}" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>

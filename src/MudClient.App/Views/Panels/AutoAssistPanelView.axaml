<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             x:Class="MudClient.App.Views.Panels.AutoAssistPanelView"
             x:DataType="vm:MainWindowViewModel">
  <StackPanel Spacing="10" Margin="12">
    <TextBlock Classes="mud-heading" Text="AUTOASSIST" />
    <CheckBox IsChecked="{Binding AutoAssistEnabled}"
              Content="Włącz automatyczne wspieranie drużyny" />
    <TextBlock Classes="mud-faint" TextWrapping="Wrap"
               Text="Gdy GMCP wykryje, że inny członek drużyny walczy w tym samym pokoju, klient wyśle „as”. Jeśli przestaniesz walczyć, a członek drużyny nadal walczy, komenda zostanie ponowiona." />
  </StackPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             x:Class="MudClient.App.Views.Panels.GroupOrdersPanelView"
             x:DataType="vm:MainWindowViewModel">
  <StackPanel Spacing="10" Margin="12">
    <TextBlock Classes="mud-heading" Text="ORDERY" />
    <CheckBox IsChecked="{Binding GroupOrdersEnabled}"
              Content="Wykonuj rozkazy członków drużyny" />
    <TextBlock Classes="mud-faint" TextWrapping="Wrap"
               Text="Klient wykona komendę z komunikatu „Gracz rozkazuje ci 'komenda'.” tylko wtedy, gdy Gracz znajduje się w aktualnej grupie GMCP." />
  </StackPanel>
</UserControl>

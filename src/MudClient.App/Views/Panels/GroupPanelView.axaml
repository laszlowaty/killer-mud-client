<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:models="using:MudClient.App.Models"
             x:Class="MudClient.App.Views.Panels.GroupPanelView"
             x:Name="GroupPanel"
             x:DataType="vm:MainWindowViewModel">
  <!-- Group (live from Char.Group GMCP) -->
  <ScrollViewer>
    <StackPanel Spacing="2" Margin="12">
      <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                 Text="{Binding GroupEmptyMessage}"
                 IsVisible="{Binding !Group.Count}" />
      <ItemsControl x:Name="GroupMembersList" ItemsSource="{Binding Group}">
        <ItemsControl.ContextMenu>
          <ContextMenu x:Name="GroupContextMenu" x:DataType="models:GroupMember"
                       Opened="GroupContextMenu_OnOpened"
                       Closed="GroupContextMenu_OnClosed">
            <MenuItem Header="goto room"
                      Command="{Binding #GroupPanel.DataContext.LordGotoGroupRoomCommand}"
                      CommandParameter="{Binding}"
                      IsVisible="{Binding #GroupPanel.DataContext.LordModeEnabled}" />
            <MenuItem Header="{Binding Name, StringFormat='goto {0}'}"
                      Command="{Binding #GroupPanel.DataContext.LordGotoGroupMemberCommand}"
                      CommandParameter="{Binding}"
                      IsVisible="{Binding #GroupPanel.DataContext.LordModeEnabled}" />
          </ContextMenu>
        </ItemsControl.ContextMenu>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:GroupMember">
            <Border Classes="mud-section" Padding="6,4" Margin="0,1"
                    ContextRequested="GroupMember_OnContextRequested">
              <StackPanel Spacing="2">
                <!-- Row 1: leader marker + name + NPC marker -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding LeaderMarker}"
                             Foreground="{StaticResource MudBrushGoldBright}"
                             />
                  <TextBlock Text="{Binding Name}" />
                  <TextBlock Text="{Binding NpcDisplay}"
                             Foreground="{StaticResource MudBrushParchmentDim}" />
                </StackPanel>
                <!-- Row 2: HP + MV + MEM -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock
                             Foreground="{StaticResource MudBrushCrimson}"
                             Text="{Binding HpDisplay}" />
                  <TextBlock
                             Foreground="{StaticResource MudBrushEmerald}"
                             Text="{Binding MvDisplay}" />
                  <TextBlock
                             Foreground="{StaticResource MudBrushArcaneBlueBright}"
                             Text="{Binding MemDisplay}"
                             IsVisible="{Binding MemDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
                <!-- Row 3: position + room -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Foreground="{StaticResource MudBrushParchmentDim}"
                             ToolTip.Tip="Pozycja"
                             Text="{Binding PositionDisplay}" />
                  <TextBlock Foreground="{StaticResource MudBrushParchmentFaint}"
                             ToolTip.Tip="Pokój"
                             Text="{Binding RoomDisplay}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:MudClient.App.Controls"
             xmlns:models="using:MudClient.App.Models"
             xmlns:vm="using:MudClient.App.ViewModels"
             x:Class="MudClient.App.Views.Panels.TerminalPanelView"
             x:DataType="vm:MainWindowViewModel">
  <Grid RowDefinitions="*,Auto" ColumnDefinitions="48,*,48">

    <!-- HP vertical indicator (left) – spans full panel height -->
    <Border Grid.Column="0" Grid.RowSpan="2"
            Padding="2,8" Margin="2,0,0,0"
            Background="{StaticResource MudBrushStone}" CornerRadius="3">
      <Grid RowDefinitions="Auto,*,Auto" RowSpacing="3">
        <TextBlock Grid.Row="0" Text="HP" FontSize="9" FontWeight="Bold"
                   Foreground="{StaticResource MudBrushCrimsonBright}"
                   HorizontalAlignment="Center" />
        <ProgressBar Grid.Row="1" Orientation="Vertical"
                     Minimum="0"
                     Maximum="{Binding Vitals.MaxHitPoints}"
                     Value="{Binding Vitals.HitPoints}"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Center" Width="14"
                     Foreground="{StaticResource MudBrushCrimson}"
                     Background="{StaticResource MudBrushVoid}" />
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="1">
          <TextBlock Text="{Binding Vitals.HitPoints}" FontSize="9"
                     Foreground="{StaticResource MudBrushParchment}" />
          <TextBlock Text="/" FontSize="9"
                     Foreground="{StaticResource MudBrushParchmentFaint}" />
          <TextBlock Text="{Binding Vitals.MaxHitPoints}" FontSize="8"
                     Foreground="{StaticResource MudBrushParchmentFaint}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- MUD output (center) -->
    <Grid Grid.Column="1" Grid.Row="0">
      <controls:MudOutputView x:Name="MudOutput"
                              OutputFontFamily="{Binding OutputFontFamilyValue}"
                              OutputFontSize="{Binding OutputFontSize}"
                              OutputFontWeight="{Binding OutputFontWeight}"
                              TelnetColorScheme="{Binding TelnetColorScheme}"
                              WordWrap="{Binding OutputWordWrap}" />

      <ItemsControl ItemsSource="{Binding Timers}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,22,0"
                    IsHitTestVisible="False">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:TimerEntry">
            <Border IsVisible="{Binding IsEnabled}"
                    MinWidth="112"
                    Margin="0,0,0,4"
                    Padding="7,4"
                    CornerRadius="4"
                    Background="{StaticResource MudBrushVoid}"
                    BorderBrush="{StaticResource MudBrushGoldDim}"
                    BorderThickness="1"
                    Opacity="0.9"
                    ToolTip.Tip="{Binding Name}">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="{Binding ShortName}"
                           FontSize="11"
                           Foreground="{StaticResource MudBrushParchmentDim}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding RemainingText}"
                           MinWidth="42"
                           TextAlignment="Right"
                           FontFamily="Consolas"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="{StaticResource MudBrushGoldBright}" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>

    <!-- Command bar -->
    <Border Grid.Column="1" Grid.Row="1" Classes="mud-bar-bottom" Padding="8,6">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
        <TextBox Grid.Column="0"
                 x:Name="CommandBox"
                 Classes="terminal-input"
                 Text="{Binding CommandText}"
                 PlaceholderText="Wpisz komendę (Enter or Shift+Enter)"
                 AcceptsReturn="True"
                 AcceptsTab="False"
                 TextWrapping="Wrap"
                 MaxHeight="120"
                 KeyDown="CommandBox_OnKeyDown" />
        <TextBox Grid.Column="1"
                 x:Name="SearchBox"
                 Width="190"
                 MinHeight="30"
                 PlaceholderText="Wyszukaj..."
                 ToolTip.Tip="Szukaj w terminalu (Enter/▲: starsze, Shift+Enter/▼: nowsze)"
                 TextChanged="SearchBox_OnTextChanged"
                 KeyDown="SearchBox_OnKeyDown" />
        <Button Grid.Column="2"
                x:Name="SearchPrevButton"
                Classes="mud-small"
                Content="▲"
                MinWidth="0"
                Padding="8,7"
                ToolTip.Tip="Poprzednie dopasowanie (starsze)"
                Click="SearchPrevButton_OnClick" />
        <Button Grid.Column="3"
                x:Name="SearchNextButton"
                Classes="mud-small"
                Content="▼"
                MinWidth="0"
                Padding="8,7"
                ToolTip.Tip="Następne dopasowanie (nowsze)"
                Click="SearchNextButton_OnClick" />
        <Button Grid.Column="4"
                Content="➤"
                Padding="20,7"
                ToolTip.Tip="Wyślij"
                Command="{Binding SendCommandCommand}"
                Click="SendButton_OnClick" />
      </Grid>
    </Border>

    <!-- MV vertical indicator (right) – spans full panel height -->
    <Border Grid.Column="2" Grid.RowSpan="2"
            Padding="2,8" Margin="0,0,2,0"
            Background="{StaticResource MudBrushStone}" CornerRadius="3">
      <Grid RowDefinitions="Auto,*,Auto" RowSpacing="3">
        <TextBlock Grid.Row="0" Text="MV" FontSize="9" FontWeight="Bold"
                   Foreground="{StaticResource MudBrushEmeraldBright}"
                   HorizontalAlignment="Center" />
        <ProgressBar Grid.Row="1" Orientation="Vertical"
                     Minimum="0"
                     Maximum="{Binding Vitals.MaxEndurancePoints}"
                     Value="{Binding Vitals.EndurancePoints}"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Center" Width="14"
                     Foreground="{StaticResource MudBrushEmerald}"
                     Background="{StaticResource MudBrushVoid}" />
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="1">
          <TextBlock Text="{Binding Vitals.EndurancePoints}" FontSize="9"
                     Foreground="{StaticResource MudBrushParchment}" />
          <TextBlock Text="/" FontSize="9"
                     Foreground="{StaticResource MudBrushParchmentFaint}" />
          <TextBlock Text="{Binding Vitals.MaxEndurancePoints}" FontSize="8"
                     Foreground="{StaticResource MudBrushParchmentFaint}" />
        </StackPanel>
      </Grid>
    </Border>

  </Grid>
</UserControl>

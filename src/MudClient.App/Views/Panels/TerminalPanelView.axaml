<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:MudClient.App.Controls"
             xmlns:vm="using:MudClient.App.ViewModels"
             x:Class="MudClient.App.Views.Panels.TerminalPanelView"
             x:DataType="vm:MainWindowViewModel">
  <Grid RowDefinitions="*,Auto" ColumnDefinitions="48,*,48">

    <!-- HP vertical indicator (left) – spans full panel height -->
    <Border Grid.Column="0" Grid.RowSpan="2"
            Padding="2,8" Margin="2,0,0,0"
            Background="{StaticResource MudBrushStone}" CornerRadius="3">
      <Grid RowDefinitions="Auto,*,Auto" RowSpacing="3">
        <TextBlock Grid.Row="0" Text="HP" FontSize="9" FontWeight="Bold"
                   Foreground="{StaticResource MudBrushCrimsonBright}"
                   HorizontalAlignment="Center" />
        <ProgressBar Grid.Row="1" Orientation="Vertical"
                     Minimum="0"
                     Maximum="{Binding Vitals.MaxHitPoints}"
                     Value="{Binding Vitals.HitPoints}"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Center" Width="14"
                     Foreground="{StaticResource MudBrushCrimson}"
                     Background="{StaticResource MudBrushVoid}" />
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="1">
          <TextBlock Text="{Binding Vitals.HitPoints}" FontSize="9"
                     Foreground="{StaticResource MudBrushParchment}" />
          <TextBlock Text="/" FontSize="9"
                     Foreground="{StaticResource MudBrushParchmentFaint}" />
          <TextBlock Text="{Binding Vitals.MaxHitPoints}" FontSize="8"
                     Foreground="{StaticResource MudBrushParchmentFaint}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- MUD output (center) -->
    <controls:MudOutputView Grid.Column="1" Grid.Row="0"
                            x:Name="MudOutput"
                            OutputFontFamily="{Binding OutputFontFamilyValue}"
                            OutputFontSize="{Binding OutputFontSize}"
                            OutputFontWeight="{Binding OutputFontWeight}"
                            TelnetColorScheme="{Binding TelnetColorScheme}"
                            WordWrap="{Binding OutputWordWrap}" />

    <!-- Command bar -->
    <Border Grid.Column="1" Grid.Row="1" Classes="mud-bar-bottom" Padding="8,6">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <TextBox Grid.Column="0"
                 x:Name="CommandBox"
                 Classes="terminal-input"
                 Text="{Binding CommandText}"
                 PlaceholderText="Wpisz komendę i naciśnij Enter…"
                 KeyDown="CommandBox_OnKeyDown" />
        <Button Grid.Column="1"
                Content="➤ Wyślij"
                Padding="20,7"
                Command="{Binding SendCommandCommand}"
                Click="SendButton_OnClick" />
      </Grid>
    </Border>

    <!-- MV vertical indicator (right) – spans full panel height -->
    <Border Grid.Column="2" Grid.RowSpan="2"
            Padding="2,8" Margin="0,0,2,0"
            Background="{StaticResource MudBrushStone}" CornerRadius="3">
      <Grid RowDefinitions="Auto,*,Auto" RowSpacing="3">
        <TextBlock Grid.Row="0" Text="MV" FontSize="9" FontWeight="Bold"
                   Foreground="{StaticResource MudBrushEmeraldBright}"
                   HorizontalAlignment="Center" />
        <ProgressBar Grid.Row="1" Orientation="Vertical"
                     Minimum="0"
                     Maximum="{Binding Vitals.MaxEndurancePoints}"
                     Value="{Binding Vitals.EndurancePoints}"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Center" Width="14"
                     Foreground="{StaticResource MudBrushEmerald}"
                     Background="{StaticResource MudBrushVoid}" />
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="1">
          <TextBlock Text="{Binding Vitals.EndurancePoints}" FontSize="9"
                     Foreground="{StaticResource MudBrushParchment}" />
          <TextBlock Text="/" FontSize="9"
                     Foreground="{StaticResource MudBrushParchmentFaint}" />
          <TextBlock Text="{Binding Vitals.MaxEndurancePoints}" FontSize="8"
                     Foreground="{StaticResource MudBrushParchmentFaint}" />
        </StackPanel>
      </Grid>
    </Border>

  </Grid>
</UserControl>

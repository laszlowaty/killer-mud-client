<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:models="using:MudClient.App.Models"
             x:Class="MudClient.App.Views.Panels.CharacterPanelView"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer>
    <StackPanel Spacing="8" Margin="12">

      <!-- Character info -->
      <TextBlock Classes="mud-heading" Text="INFORMACJE" />
      <Border Classes="mud-section">
        <StackPanel Spacing="4" DataContext="{Binding Vitals}">
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Classes="mud-muted" Text="Imię:" />
            <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                       Text="{Binding Name}" FontWeight="SemiBold"
                       Foreground="{StaticResource MudBrushGoldBright}" />
          </Grid>
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Classes="mud-muted" Text="Poziom:" />
            <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                       Text="{Binding Level}" FontWeight="Bold" />
          </Grid>
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Classes="mud-muted" Text="Płeć:" />
            <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                       Text="{Binding SexDisplay}" />
          </Grid>
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Classes="mud-muted" Text="Pozycja:" />
            <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                       Text="{Binding PositionDisplay}"
                       Foreground="{StaticResource MudBrushArcaneBlue}" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Conditions (live from Char.Condition GMCP) -->
      <TextBlock Classes="mud-heading" Text="KONDYCJA" Margin="0,6,0,0" />
      <Border Classes="mud-section" Padding="8,6">
        <StackPanel Spacing="4">
          <TextBlock Classes="mud-faint" Text="W pełni sił — brak dolegliwości."
                     IsVisible="{Binding !Conditions.Count}" />
          <ItemsControl ItemsSource="{Binding Conditions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="x:String">
                <Border Background="{StaticResource MudBrushStoneLight}"
                        BorderBrush="{StaticResource MudBrushCrimson}"
                        BorderThickness="1"
                        CornerRadius="3" Padding="7,3" Margin="0,2,4,2">
                  <TextBlock Text="{Binding}" FontSize="11"
                             Foreground="{StaticResource MudBrushCrimsonBright}" />
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Effects (live from Char.Affects GMCP) -->
      <TextBlock Classes="mud-heading" Text="EFEKTY" Margin="0,6,0,0" />
      <Border Classes="mud-section" Padding="8,6">
        <StackPanel Spacing="2">
          <TextBlock Classes="mud-faint" Text="Brak aktywnych efektów."
                     IsVisible="{Binding !Effects.Count}" />
          <ItemsControl ItemsSource="{Binding Effects}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:StatusEffect">
                <Grid>
                  <Border BorderBrush="{StaticResource MudBrushCrimson}"
                          BorderThickness="1"
                          CornerRadius="3"
                          Padding="6,3"
                          Margin="0,1"
                          IsVisible="{Binding IsDebuff}">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          RowDefinitions="Auto,Auto">
                      <TextBlock Grid.Column="0" Grid.Row="0"
                                 Text="{Binding Icon}" FontSize="12"
                                 Foreground="{StaticResource MudBrushCrimsonBright}"
                                 Margin="0,0,6,0" />
                      <TextBlock Grid.Column="1" Grid.Row="0"
                                 Text="{Binding Name}" FontSize="12"
                                 Foreground="{StaticResource MudBrushCrimsonBright}"
                                 ToolTip.Tip="{Binding Description}" />
                      <TextBlock Grid.Column="2" Grid.Row="0"
                                 Text="{Binding Duration}"
                                 FontSize="11"
                                 Classes="mud-faint"
                                 HorizontalAlignment="Right"
                                 Margin="6,0,0,0"
                                 IsVisible="{Binding HasDuration}" />
                      <TextBlock Grid.Column="1" Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding Description}"
                                 FontSize="10"
                                 Classes="mud-faint"
                                 TextTrimming="CharacterEllipsis"
                                 IsVisible="{Binding HasDescription}" />
                    </Grid>
                  </Border>
                  <Border BorderBrush="{StaticResource MudBrushEmerald}"
                          BorderThickness="1"
                          CornerRadius="3"
                          Padding="6,3"
                          Margin="0,1"
                          IsVisible="{Binding !IsDebuff}">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          RowDefinitions="Auto,Auto">
                      <TextBlock Grid.Column="0" Grid.Row="0"
                                 Text="{Binding Icon}" FontSize="12"
                                 Foreground="{StaticResource MudBrushEmeraldBright}"
                                 Margin="0,0,6,0" />
                      <TextBlock Grid.Column="1" Grid.Row="0"
                                 Text="{Binding Name}" FontSize="12"
                                 ToolTip.Tip="{Binding Description}" />
                      <TextBlock Grid.Column="2" Grid.Row="0"
                                 Text="{Binding Duration}"
                                 FontSize="11"
                                 Classes="mud-faint"
                                 HorizontalAlignment="Right"
                                 Margin="6,0,0,0"
                                 IsVisible="{Binding HasDuration}" />
                      <TextBlock Grid.Column="1" Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding Description}"
                                 FontSize="10"
                                 Classes="mud-faint"
                                 TextTrimming="CharacterEllipsis"
                                 IsVisible="{Binding HasDescription}" />
                    </Grid>
                  </Border>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- People in room -->
      <TextBlock Classes="mud-heading" Text="W POKOJU" Margin="0,6,0,0" />
      <Border Classes="mud-section" Padding="8,6">
        <StackPanel Spacing="2">
          <TextBlock Classes="mud-faint" Text="Nikogo tu nie ma."
                     IsVisible="{Binding !People.Count}" />
          <ItemsControl ItemsSource="{Binding People}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:PersonEntry">
                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" Margin="0,1">
                  <TextBlock Grid.Column="0" Text="•" Classes="mud-muted" Margin="0,0,6,0" />
                  <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" />
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                              IsVisible="{Binding !IsSelf}">
                    <Button Content="exa" Classes="mud-small" Padding="6,1" FontSize="11"
                            Command="{Binding $parent[UserControl].DataContext.ExaminePersonCommand}"
                            CommandParameter="{Binding Name}" />
                    <Button Content="kill" Classes="mud-small mud-danger" Padding="6,1" FontSize="11"
                            Command="{Binding $parent[UserControl].DataContext.KillPersonCommand}"
                            CommandParameter="{Binding Name}" />
                  </StackPanel>
                  <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                             Text="{Binding FightingText}"
                             FontSize="11"
                             Foreground="{StaticResource MudBrushCrimsonBright}"
                             IsVisible="{Binding IsFighting}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Group (live from Char.Group GMCP) -->
      <TextBlock Classes="mud-heading" Text="DRUŻYNA" Margin="0,6,0,0" />
      <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                 Text="Brak członków drużyny."
                 IsVisible="{Binding !Group.Count}" />
      <ItemsControl ItemsSource="{Binding Group}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:GroupMember">
            <Border Classes="mud-section" Padding="6,4" Margin="0,1">
              <StackPanel Spacing="2">
                <!-- Row 1: leader marker + name + NPC marker -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding LeaderMarker}"
                             Foreground="{StaticResource MudBrushGoldBright}"
                             FontWeight="Bold" />
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" />
                  <TextBlock Text="{Binding NpcDisplay}"
                             FontSize="9"
                             Foreground="{StaticResource MudBrushParchmentDim}" />
                </StackPanel>
                <!-- Row 2: HP + MV + MEM -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock FontSize="10"
                             Foreground="{StaticResource MudBrushCrimson}"
                             Text="{Binding HpDisplay}" />
                  <TextBlock FontSize="10"
                             Foreground="{StaticResource MudBrushEmerald}"
                             Text="{Binding MvDisplay}" />
                  <TextBlock FontSize="10"
                             Foreground="{StaticResource MudBrushArcaneBlueBright}"
                             Text="{Binding MemDisplay}"
                             IsVisible="{Binding MemDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
                <!-- Row 3: position + room -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock FontSize="10" Foreground="{StaticResource MudBrushParchmentDim}"
                             ToolTip.Tip="Pozycja"
                             Text="{Binding PositionDisplay}" />
                  <TextBlock FontSize="10" Foreground="{StaticResource MudBrushParchmentFaint}"
                             ToolTip.Tip="Pokój"
                             Text="{Binding RoomDisplay}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Memorized spells (live from Char.MemSpell GMCP) -->
      <TextBlock Classes="mud-heading" Text="MEM (ZAKLĘCIA)" Margin="0,6,0,0" />
      <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                 Text="Brak zapamiętanych zaklęć."
                 IsVisible="{Binding !MemSpells.Count}" />
      <ItemsControl ItemsSource="{Binding MemSpells}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:MemSpellCircle">
            <Border Classes="mud-section" Padding="6,4" Margin="0,1">
              <StackPanel Spacing="2">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="12"
                             Foreground="{StaticResource MudBrushArcaneBlueBright}" />
                  <TextBlock Grid.Column="1" Text="{Binding CountDisplay}"
                             FontSize="11" Classes="mud-faint" />
                </Grid>
                <TextBlock Text="{Binding MemedDisplay}"
                           FontSize="10" TextWrapping="Wrap"
                           IsVisible="{Binding HasMemed}" />
                <TextBlock Text="{Binding MemingDisplay}"
                           FontSize="10" TextWrapping="Wrap"
                           Foreground="{StaticResource MudBrushGoldBright}"
                           ToolTip.Tip="W trakcie zapamiętywania"
                           IsVisible="{Binding HasMeming}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>

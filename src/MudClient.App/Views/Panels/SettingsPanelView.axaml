<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:services="using:MudClient.App.Services"
             x:Class="MudClient.App.Views.Panels.SettingsPanelView"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer>
    <StackPanel Spacing="8" Margin="12">

      <TextBlock Classes="mud-heading" Text="USTAWIENIA SYSTEMOWE" />
      <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                 Text="Wspólne dla wszystkich kont. Zapisywane automatycznie." />

      <TextBlock Classes="mud-heading" Text="TEKST Z MUDA" Margin="0,6,0,0" />
      <Border Classes="mud-section" Padding="10">
        <StackPanel Spacing="10">

          <StackPanel Spacing="3">
            <TextBlock Classes="mud-faint" Text="Czcionka" />
            <ComboBox ItemsSource="{Binding AvailableFonts}"
                      SelectedItem="{Binding OutputFontFamily}"
                      HorizontalAlignment="Stretch"
                      MaxDropDownHeight="320">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <TextBlock Text="{Binding}"
                             FontFamily="{Binding Converter={x:Static services:AppFontFamilyConverter.Instance}}"
                             FontSize="13" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <CheckBox Content="Zawijaj długie linie w oknie terminala"
                    IsChecked="{Binding OutputWordWrap}" />

          <CheckBox Content="Pogrubiona"
                    IsChecked="{Binding OutputFontBold}" />

          <StackPanel Spacing="3">
            <TextBlock Classes="mud-faint" Text="Schemat kolorów Telnet/ANSI" />
            <ComboBox ItemsSource="{Binding AvailableTelnetColorSchemes}"
                      SelectedItem="{Binding TelnetColorScheme}"
                      HorizontalAlignment="Stretch" />
            <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                       Text="Zmienia standardowe 16 kolorów. Kolory RGB wysłane przez MUD pozostają bez zmian." />
          </StackPanel>

          <StackPanel Spacing="3">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Classes="mud-faint" Text="Rozmiar" />
              <Border Grid.Column="1" Classes="mud-badge mud-badge-gold">
                <TextBlock Text="{Binding OutputFontSizeText}" />
              </Border>
            </Grid>
            <Slider Minimum="{Binding MinOutputFontSize}"
                    Maximum="{Binding MaxOutputFontSize}"
                    Value="{Binding OutputFontSize}"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True" />
          </StackPanel>

          <StackPanel Spacing="3">
            <TextBlock Classes="mud-faint" Text="Podgląd" />
            <Border Classes="mud-inset" Padding="10,8">
              <TextBlock Text="Strażnik miasta wchodzi z północy.&#x0a;&gt; zabij straznika"
                         FontFamily="{Binding OutputFontFamilyValue}"
                         FontSize="{Binding OutputFontSize}"
                         FontWeight="{Binding OutputFontWeight}"
                         Foreground="{StaticResource MudBrushParchment}"
                         TextWrapping="Wrap" />
            </Border>
          </StackPanel>

          <Button Content="Przywróć domyślne"
                  Command="{Binding ResetOutputFontCommand}"
                  Classes="mud-small"
                  HorizontalAlignment="Right" />

        </StackPanel>
      </Border>

      <TextBlock Classes="mud-heading" Text="WIDGETY" Margin="0,6,0,0" />
      <Border Classes="mud-section" Padding="10">
        <StackPanel Spacing="10">
          <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                     Text="Wspólna czcionka wszystkich paneli poza terminalem." />
          <StackPanel Spacing="3">
            <TextBlock Classes="mud-faint" Text="Czcionka" />
            <ComboBox ItemsSource="{Binding AvailableFonts}"
                      SelectedItem="{Binding WidgetFontFamily}"
                      HorizontalAlignment="Stretch"
                      MaxDropDownHeight="320">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <TextBlock Text="{Binding}"
                             FontFamily="{Binding Converter={x:Static services:AppFontFamilyConverter.Instance}}"
                             FontSize="13" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
          <StackPanel Spacing="3">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Classes="mud-faint" Text="Rozmiar" />
              <Border Grid.Column="1" Classes="mud-badge mud-badge-gold">
                <TextBlock Text="{Binding WidgetFontSizeText}" />
              </Border>
            </Grid>
            <Slider Minimum="{Binding MinWidgetFontSize}"
                    Maximum="{Binding MaxWidgetFontSize}"
                    Value="{Binding WidgetFontSize}"
                    TickFrequency="1" IsSnapToTickEnabled="True" />
          </StackPanel>
          <CheckBox Content="Pogrubiona"
                    IsChecked="{Binding WidgetFontBold}" />
          <Border Classes="mud-inset" Padding="10,8">
            <TextBlock Text="Podgląd tekstu w widżetach"
                       FontFamily="{Binding WidgetFontFamilyValue}"
                       FontSize="{Binding WidgetFontSize}"
                       FontWeight="{Binding WidgetFontWeight}" />
          </Border>
          <Button Content="Przywróć domyślne"
                  Command="{Binding ResetWidgetFontCommand}"
                  Classes="mud-small" HorizontalAlignment="Right" />
        </StackPanel>
      </Border>

      <TextBlock Classes="mud-heading" Text="KOMENDY" Margin="0,6,0,0" />
      <Border Classes="mud-section" Padding="10">
        <StackPanel Spacing="10">

          <CheckBox Content="Czyść pole komendy po wysłaniu"
                    IsChecked="{Binding ClearCommandInputAfterSend}" />

          <StackPanel Spacing="3">
            <TextBlock Classes="mud-faint" Text="Separator składania komend" />
            <TextBox Text="{Binding CommandStackingSeparator}"
                     MaxLength="10"
                     Width="100"
                     HorizontalAlignment="Left" />
            <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                       Text="Globalny separator dla komend wpisywanych, aliasów, triggerów i timerów. Pusta wartość wyłącza składanie (tylko nowe linie). Zapisywane automatycznie." />
          </StackPanel>

        </StackPanel>
      </Border>

      <TextBlock Classes="mud-heading" Text="KOPIA USTAWIEŃ" Margin="0,6,0,0" />
      <Border Classes="mud-section" Padding="10">
        <StackPanel Spacing="10">
          <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                     Text="Eksport obejmuje cały katalog danych aplikacji: ustawienia, konta i profile, automatyzację, zapisany układ oraz pozostałe dane." />
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button x:Name="ExportSettingsButton"
                    Content="Eksportuj do ZIP"
                    Classes="mud-small"
                    Click="ExportSettings_OnClick" />
            <Button x:Name="ImportSettingsButton"
                    Content="Importuj z ZIP"
                    Classes="mud-small"
                    Click="ImportSettings_OnClick" />
          </StackPanel>
          <TextBlock x:Name="SettingsTransferStatusText"
                     Classes="mud-faint"
                     TextWrapping="Wrap"
                     IsVisible="False" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:MudClient.App.Controls"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:map="using:MudClient.Core.Map"
             x:Class="MudClient.App.Views.Panels.MapPanelView"
             x:DataType="vm:MapViewModel">
  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ========================================================================
          Header bar: area / Z selector + toolbar (responsive WrapPanel)
          ======================================================================== -->
    <Border Grid.Row="0" Classes="mud-bar" Padding="10,6">
      <WrapPanel>

        <!-- Area selector group -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,8,4">
          <TextBlock Classes="mud-heading" Text="OBSZAR" VerticalAlignment="Center" />
          <ComboBox ItemsSource="{Binding Areas}"
                    SelectedItem="{Binding SelectedArea}"
                    MinWidth="150">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="map:MapArea">
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <!-- Z level selector group -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,8,4">
          <TextBlock Classes="mud-heading" Text="POZIOM Z" VerticalAlignment="Center" />
          <ComboBox ItemsSource="{Binding ZLevels}"
                    SelectedItem="{Binding SelectedZ}"
                    MinWidth="70" />
        </StackPanel>

        <!-- Follow toggle -->
        <ToggleButton Content="Śledź"
                      IsChecked="{Binding FollowPlayer}"
                      Padding="8,4"
                      VerticalAlignment="Center"
                      Margin="0,0,8,4" />

        <!-- Toolbar buttons -->
        <StackPanel Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center"
                    Margin="0,0,8,4">
          <Button Content="Wycentruj"
                  Command="{Binding CenterCommand}"
                  Padding="10,5" />
          <Button Content="Reset zoom"
                  Command="{Binding ResetZoomCommand}"
                  Padding="10,5" />
        </StackPanel>

        <!-- Current room info -->
        <Border Background="{StaticResource MudBrushStone}"
                CornerRadius="3" Padding="6,3"
                VerticalAlignment="Center"
                Margin="0,0,8,4">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Classes="mud-faint" Text="VNUM:" />
            <TextBlock Classes="mud-status-info" Text="{Binding CurrentVnum}" />
          </StackPanel>
        </Border>

        <Border Background="{StaticResource MudBrushStone}"
                CornerRadius="3" Padding="6,3"
                VerticalAlignment="Center"
                Margin="0,0,8,4">
          <TextBlock Text="{Binding CurrentRoomName}"
                     MaxWidth="150"
                     TextTrimming="CharacterEllipsis" />
        </Border>

        <Border Background="{StaticResource MudBrushStone}"
                CornerRadius="3" Padding="6,3"
                VerticalAlignment="Center"
                Margin="0,0,8,4">
          <TextBlock Classes="mud-muted" Text="{Binding CurrentSectorName}" />
        </Border>

      </WrapPanel>
    </Border>

    <!-- ========================================================================
          Map content area
          ======================================================================== -->
    <Border Grid.Row="1" Background="Black">
      <Panel>
        <controls:WorldMapControl x:Name="MapControl"
                                  WidgetFontFamily="{DynamicResource WidgetFontFamilyResource}"
                                  WidgetFontSize="{DynamicResource WidgetFontSizeResource}"
                                  WidgetFontWeight="{DynamicResource WidgetFontWeightResource}" />

        <!-- Loading overlay -->
        <Border Background="#CC101010"
                IsVisible="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20,12"
                CornerRadius="6">
          <TextBlock Text="{Binding StatusMessage}" Foreground="White" />
        </Border>

        <!-- Error overlay -->
        <Border Background="#CC401010"
                IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,12,0,0"
                Padding="16,10"
                CornerRadius="6">
          <StackPanel Spacing="6">
            <SelectableTextBlock Text="{Binding ErrorMessage}"
                                  Foreground="White"
                                  TextWrapping="Wrap"
                                  MaxWidth="480" />
            <Button Content="Spróbuj ponownie"
                    Command="{Binding ReloadCommand}"
                    HorizontalAlignment="Left"
                    Padding="12,6" />
          </StackPanel>
        </Border>
      </Panel>
    </Border>

    <!-- ========================================================================
         Footer bar: status message
         ======================================================================== -->
    <Border Grid.Row="2" Classes="mud-bar-bottom" Padding="10,5">
      <TextBlock Classes="mud-faint" Text="{Binding StatusMessage}" />
    </Border>

  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:MudClient.App.Controls"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:map="using:MudClient.Core.Map"
             x:Class="MudClient.App.Views.Panels.MapPanelView"
             x:DataType="vm:MapViewModel">
  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ========================================================================
          Header bar
          ======================================================================== -->
    <Border Grid.Row="0" Classes="mud-bar" Padding="10,6">
      <WrapPanel>

        <Button x:Name="MapMenuButton"
                Content="Mapa ▾"
                Padding="10,5"
                VerticalAlignment="Center"
                Margin="0,0,8,4">
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedLeft">
              <StackPanel Spacing="6" MinWidth="230">
                <TextBlock Classes="mud-heading" Text="OBSZAR" />
                <ComboBox x:Name="AreaSelector"
                          ItemsSource="{Binding Areas}"
                          SelectedItem="{Binding SelectedArea}"
                          HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="map:MapArea">
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Classes="mud-heading" Text="POZIOM Z" Margin="0,4,0,0" />
                <ComboBox x:Name="ZSelector"
                          ItemsSource="{Binding ZLevels}"
                          SelectedIndex="{Binding SelectedZIndex, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" />
                <Border Height="1"
                        Background="{StaticResource MudBrushSlate}"
                        Margin="0,4" />
                <Button Content="Wycentruj i śledź"
                        Command="{Binding CenterCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="10,6" />
                <ToggleSwitch Content="Tryb lorda"
                              IsChecked="{Binding LordModeEnabled}"
                              ToolTip.Tip="Udostępnia polecenie goto w menu prawego przycisku mapy." />
                <StackPanel x:Name="MapEditorPanel" Spacing="6" IsVisible="{Binding LordModeEnabled}">
                  <Border Height="1"
                          Background="{StaticResource MudBrushSlate}"
                          Margin="0,4" />
                  <TextBlock Classes="mud-heading" Text="EDYTOR MAPY" />
                  <WrapPanel>
                    <Button Content="Rozpocznij mapowanie"
                            Command="{Binding StartMapEditorCommand}"
                            IsVisible="{Binding !IsMapEditorActive}"
                            Margin="0,0,6,4"
                            Padding="10,6" />
                    <Button Content="Zatrzymaj mapowanie"
                            Command="{Binding StopMapEditorCommand}"
                            IsVisible="{Binding IsMapEditorActive}"
                            Margin="0,0,6,4"
                            Padding="10,6" />
                  </WrapPanel>
                  <WrapPanel>
                    <Button Content="Zapisz"
                            Command="{Binding SaveMapEditorCommand}"
                            Margin="0,0,6,4"
                            Padding="10,6" />
                    <Button Content="Cofnij"
                            Command="{Binding UndoMapEditorCommand}"
                            Margin="0,0,6,4"
                            Padding="10,6" />
                    <Button Content="Ponów"
                            Command="{Binding RedoMapEditorCommand}"
                            Margin="0,0,6,4"
                            Padding="10,6" />
                  </WrapPanel>
                  <TextBlock Classes="mud-faint"
                             Text="{Binding MapEditorStatus}"
                             MaxWidth="300"
                             TextWrapping="Wrap" />
                  <TextBlock Classes="mud-faint"
                             Text="{Binding MapEditorSourceDescription}"
                             MaxWidth="300"
                             TextWrapping="Wrap" />
                  <TextBlock Classes="mud-faint"
                             Text="Komendy: /map start|stop|save|undo|redo|cancel|info|check|diff|import|export|discard|resolve|step|area|room|symbol|label|forget|special (również +map)."
                             MaxWidth="300"
                             TextWrapping="Wrap" />
                </StackPanel>
                <ToggleSwitch Content="Członkowie grupy jako cyfry"
                              IsChecked="{Binding ShowGroupMembersAsNumbers}"
                              ToolTip.Tip="Numery odpowiadają kolejności członków w drużynie." />
                <Border Height="1"
                        Background="{StaticResource MudBrushSlate}"
                        Margin="0,4" />
                <TextBlock Classes="mud-heading" Text="TRYB MAPY" Margin="0,4,0,0" />
                <ComboBox ItemsSource="{Binding DisplayModes}"
                          SelectedItem="{Binding SelectedDisplayMode}"
                          HorizontalAlignment="Stretch" />
              </StackPanel>
            </Flyout>
          </Button.Flyout>
        </Button>

      </WrapPanel>
    </Border>

    <!-- ========================================================================
          Map content area
          ======================================================================== -->
    <Border Grid.Row="1" Background="Black">
      <Panel>
        <controls:WorldMapControl x:Name="MapControl"
                                  WidgetFontFamily="{DynamicResource WidgetFontFamilyResource}"
                                  WidgetFontSize="{DynamicResource WidgetFontSizeResource}"
                                  WidgetFontWeight="{DynamicResource WidgetFontWeightResource}">
          <controls:WorldMapControl.ContextMenu>
            <ContextMenu>
              <MenuItem Header="{Binding LordGotoMenuHeader}"
                        Command="{Binding LordGotoSelectedRoomCommand}"
                        IsVisible="{Binding LordModeEnabled}" />
            </ContextMenu>
          </controls:WorldMapControl.ContextMenu>
        </controls:WorldMapControl>

        <!-- Loading overlay -->
        <Border Background="#CC101010"
                IsVisible="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20,12"
                CornerRadius="6">
          <TextBlock Text="{Binding StatusMessage}" Foreground="White" />
        </Border>

        <!-- Error overlay -->
        <Border Background="#CC401010"
                IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,12,0,0"
                Padding="16,10"
                CornerRadius="6">
          <StackPanel Spacing="6">
            <SelectableTextBlock Text="{Binding ErrorMessage}"
                                  Foreground="White"
                                  TextWrapping="Wrap"
                                  MaxWidth="480" />
            <Button Content="Spróbuj ponownie"
                    Command="{Binding ReloadCommand}"
                    HorizontalAlignment="Left"
                    Padding="12,6" />
          </StackPanel>
        </Border>
      </Panel>
    </Border>

    <!-- ========================================================================
         Footer bar: status message
         ======================================================================== -->
    <Border Grid.Row="2" Classes="mud-bar-bottom" Padding="10,5">
      <StackPanel>
        <TextBlock Classes="mud-faint" Text="{Binding StatusMessage}" />
        <TextBlock Classes="mud-faint"
                   IsVisible="{Binding LordModeEnabled}"
                   Text="{Binding MapEditorStatus}" />
      </StackPanel>
    </Border>

  </Grid>
</UserControl>

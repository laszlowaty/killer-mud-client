<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:models="using:MudClient.App.Models"
             xmlns:controls="using:MudClient.App.Controls"
             x:Class="MudClient.App.Views.Panels.NotesPanelView"
             x:DataType="vm:MainWindowViewModel">
  <UserControl.Resources>
    <DataTemplate x:Key="NoteItemTemplate" x:DataType="models:NoteEntry">
      <Border Classes="mud-section" Padding="8" Margin="0,2">
        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
          <StackPanel Grid.Row="0" Grid.Column="0"
                      Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{Binding Title}"
                       VerticalAlignment="Center" />
            <Border Classes="mud-badge" IsVisible="{Binding IsGlobal}"
                    ToolTip.Tip="Wspólna dla wszystkich kont">
              <TextBlock Text="GLOBALNA" />
            </Border>
          </StackPanel>
          <Button Grid.Row="0" Grid.Column="1"
                  Classes="mud-small"
                  Content="✎" Padding="6,2"
                  ToolTip.Tip="Edytuj notatkę"
                  Click="EditNote_OnClick" />
          <Button Grid.Row="0" Grid.Column="2"
                  Classes="mud-small mud-danger"
                  Content="✕" Padding="6,2"
                  ToolTip.Tip="Usuń notatkę"
                  Click="DeleteNote_OnClick" />

          <TextBlock Grid.Row="1" Grid.ColumnSpan="3"
                     Classes="mud-muted"
                     TextWrapping="Wrap"
                     Text="{Binding Content}" />

          <TextBlock Grid.Row="2" Grid.ColumnSpan="3"
                     Classes="mud-faint"
                     Text="{Binding CreatedAt}" Margin="0,2,0,0" />
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>
  <ScrollViewer>
    <StackPanel Spacing="8" Margin="12">

      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Classes="mud-heading" Text="NOTATKI" VerticalAlignment="Center" />
        <Border Grid.Column="1" Classes="mud-badge">
          <TextBlock Text="{Binding Notes.Count}" />
        </Border>
      </Grid>

      <Expander Classes="mud-expander"
                Header="{Binding NoteFormHeader}"
                IsExpanded="{Binding IsNoteFormExpanded}">
        <StackPanel Spacing="8" Margin="0,8,0,0">
          <TextBox Text="{Binding NewNoteTitle}" PlaceholderText="Tytuł…" />
          <TextBox Text="{Binding NewNoteContent}" PlaceholderText="Treść…"
                   MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap" />
          <CheckBox IsChecked="{Binding NewNoteIsGlobal}"
                    Content="Globalna — wspólna dla wszystkich kont" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
            <Button Grid.Column="0" Content="{Binding NoteFormButtonText}"
                    Command="{Binding AddNoteCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" Padding="16,6" />
            <Button Grid.Column="1" Content="Anuluj"
                    Command="{Binding CancelNoteEditCommand}"
                    IsVisible="{Binding IsEditingNote}" Padding="16,6" />
          </Grid>
        </StackPanel>
      </Expander>

      <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                 Text="Brak notatek na tym koncie."
                 IsVisible="{Binding !Notes.Count}" />

      <Button Classes="mud-small" Content="📁 Nowy folder" Padding="10,4"
              HorizontalAlignment="Left"
              ToolTip.Tip="Utwórz folder na notatki"
              Command="{Binding CreateFolderCommand}"
              CommandParameter="{x:Static models:FolderKind.Notes}" />

      <controls:FolderTreeView Nodes="{Binding NoteTree}"
                               ItemTemplate="{StaticResource NoteItemTemplate}"
                               SupportsEnableToggle="False"
                               MoveIntoFolderCommand="{Binding MoveIntoFolderCommand}"
                               CreateSubfolderCommand="{Binding CreateSubfolderCommand}"
                               RenameFolderCommand="{Binding RenameFolderCommand}"
                               DeleteFolderCommand="{Binding DeleteFolderCommand}"
                               ToggleFolderGlobalCommand="{Binding ToggleFolderGlobalCommand}" />

    </StackPanel>
  </ScrollViewer>
</UserControl>

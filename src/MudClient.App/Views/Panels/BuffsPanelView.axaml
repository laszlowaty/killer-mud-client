<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:models="using:MudClient.App.Models"
             x:Class="MudClient.App.Views.Panels.BuffsPanelView"
             x:DataType="vm:MainWindowViewModel">
  <!-- Required buffs (user-defined, matched against Char.Affects) -->
  <ScrollViewer>
    <StackPanel Spacing="4" Margin="12">
      <Button Content="RECAST BRAKUJĄCYCH" Classes="mud-small"
              HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
              Command="{Binding RecastBuffsCommand}" />

      <Grid ColumnDefinitions="*,Auto">
        <TextBox Text="{Binding NewBuffName}" PlaceholderText="nazwa buffa (np. armor)"
                 KeyDown="NewBuffBox_OnKeyDown" />
        <Button Grid.Column="1" Content="Dodaj" Classes="mud-small" Margin="4,0,0,0"
                VerticalAlignment="Stretch"
                Command="{Binding AddBuffCommand}" />
      </Grid>

      <TextBlock Classes="mud-faint" Text="Brak zdefiniowanych buffów."
                 IsVisible="{Binding !RequiredBuffs.Count}" />

      <ItemsControl ItemsSource="{Binding RequiredBuffs}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:BuffWatchEntry">
            <Grid>
              <!-- Active: green. Clicking the whole entry recasts just this spell. -->
              <Button BorderBrush="{StaticResource MudBrushEmerald}"
                      Background="Transparent"
                      BorderThickness="1" CornerRadius="3"
                      Padding="6,3" Margin="0,1"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Cursor="Hand"
                      ToolTip.Tip="Rzuć ten spell"
                      IsVisible="{Binding IsActive}"
                      Command="{Binding $parent[UserControl].DataContext.RecastSingleBuffCommand}"
                      CommandParameter="{Binding}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock Text="[+]"
                             Foreground="{StaticResource MudBrushEmeraldBright}"
                             Margin="0,0,6,0" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding Name}"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="2" Content="✕" Classes="mud-small"
                          Padding="6,1"
                          Command="{Binding $parent[UserControl].DataContext.DeleteBuffCommand}"
                          CommandParameter="{Binding}" />
                </Grid>
              </Button>
              <!-- Missing: red -->
              <Button BorderBrush="{StaticResource MudBrushCrimson}"
                      Background="{StaticResource MudBrushStoneLight}"
                      BorderThickness="1" CornerRadius="3"
                      Padding="6,3" Margin="0,1"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Cursor="Hand"
                      ToolTip.Tip="Rzuć ten spell"
                      IsVisible="{Binding !IsActive}"
                      Command="{Binding $parent[UserControl].DataContext.RecastSingleBuffCommand}"
                      CommandParameter="{Binding}">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                  <TextBlock Text="[!]"
                             Foreground="{StaticResource MudBrushCrimsonBright}"
                             Margin="0,0,6,0" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding Name}"
                             Foreground="{StaticResource MudBrushCrimsonBright}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2" Text="brak"
                             Classes="mud-faint" Margin="0,0,6,0"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="3" Content="✕" Classes="mud-small"
                          Padding="6,1"
                          Command="{Binding $parent[UserControl].DataContext.DeleteBuffCommand}"
                          CommandParameter="{Binding}" />
                </Grid>
              </Button>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Classes="mud-faint" TextWrapping="Wrap"
                 Text="Komenda /recast wysyła cast &quot;nazwa&quot; self dla każdego brakującego buffa." />
    </StackPanel>
  </ScrollViewer>
</UserControl>

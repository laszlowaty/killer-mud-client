<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:models="using:MudClient.App.Models"
             xmlns:b="using:MudClient.App.Behaviors"
             x:Class="MudClient.App.Views.KilleropediaLoreView"
             x:DataType="vm:KilleropediaViewModel"
             Classes="killeropedia-page"
             x:Name="Root">
  <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
      <TextBox Grid.Column="0"
               Text="{Binding LoreSearchText, UpdateSourceTrigger=PropertyChanged}"
               PlaceholderText="Szukaj miejsca, postaci, wydarzenia, legendy lub wierzenia..." />
      <TextBlock Grid.Column="1"
                 Classes="mud-faint"
                 Text="{Binding FilteredLoreCountText}"
                 VerticalAlignment="Center" />
    </Grid>

    <ListBox Grid.Row="1"
             Classes="killeropedia-category-tabs"
             ItemsSource="{Binding AvailableLoreCategories}"
             SelectedItem="{Binding SelectedLoreCategory}"
             HorizontalAlignment="Left"
             ScrollViewer.HorizontalScrollBarVisibility="Auto"
             ScrollViewer.VerticalScrollBarVisibility="Disabled">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Orientation="Horizontal" Spacing="4" />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Classes="killeropedia-category-tab" Padding="10,5,10,6">
            <TextBlock Text="{Binding}" FontSize="15" LetterSpacing="0.5" />
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
      <TextBlock Grid.Column="0"
                 Classes="mud-faint"
                 Text="{Binding LoreCatalogWarning}"
                 IsVisible="{Binding HasLoreCatalogWarning}"
                 TextTrimming="CharacterEllipsis" />
      <TextBlock Grid.Column="1"
                 Classes="mud-faint"
                 Text="{Binding LoreCatalogStatusText}" />
    </Grid>

    <Border Grid.Row="3"
            Classes="mud-section"
            Padding="18"
            IsVisible="{Binding HasNoLoreResults}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <TextBlock Classes="mud-heading-lg" Text="Brak pasujących haseł" HorizontalAlignment="Center" />
        <TextBlock Classes="mud-muted"
                   Text="Zmień wyszukiwaną frazę albo wybierz inną kategorię."
                   TextWrapping="Wrap"
                   TextAlignment="Center" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="3"
          ColumnDefinitions="1*,3,2*"
          IsVisible="{Binding !HasNoLoreResults}">
      <Border Grid.Column="0" Classes="mud-inset killeropedia-left-page" Padding="12">
        <ListBox ItemsSource="{Binding FilteredLoreEntries}"
                 SelectedItem="{Binding SelectedLoreEntry}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:LoreEntry">
              <Border Padding="10,7" Margin="0,1" CornerRadius="3">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Row="0" Grid.Column="0"
                             b:SearchHighlight.Text="{Binding Name}"
                             b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Classes="mud-faint"
                             Text="{Binding Category}" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                             Classes="mud-faint"
                             b:SearchHighlight.Text="{Binding Summary}"
                             b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <GridSplitter Grid.Column="1" ResizeDirection="Columns" />

      <Border Grid.Column="2" Classes="mud-section killeropedia-right-page" Padding="22">
        <ScrollViewer Classes="killeropedia-content-scroll"
                      b:SearchAutoScroll.Terms="{Binding LoreSearchText}"
                      b:SearchAutoScroll.Context="{Binding SelectedLoreEntry}">
          <StackPanel Spacing="12" DataContext="{Binding SelectedLoreEntry}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock Grid.Column="0" Classes="mud-heading-lg"
                         b:SearchHighlight.Text="{Binding Name}"
                         b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                         TextWrapping="Wrap" />
              <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock Classes="mud-faint" Text="{Binding KindText}" HorizontalAlignment="Right" />
                <TextBlock Classes="mud-faint" Text="{Binding StatusText}" HorizontalAlignment="Right" />
              </StackPanel>
            </Grid>

            <TextBlock Classes="mud-muted"
                       b:SearchHighlight.Text="{Binding AliasesText, StringFormat='Znane także jako: {0}'}"
                       b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                       IsVisible="{Binding HasAliases}"
                       TextWrapping="Wrap" />
            <TextBlock FontSize="16"
                       b:LoreTextLinks.Text="{Binding Summary}"
                       b:LoreTextLinks.Entries="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreEntries}"
                       b:LoreTextLinks.Command="{Binding #Root.((vm:KilleropediaViewModel)DataContext).NavigateLoreCommand}"
                       b:LoreTextLinks.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                       b:LoreTextLinks.CurrentEntryId="{Binding #Root.((vm:KilleropediaViewModel)DataContext).SelectedLoreEntry.Id}"
                       TextWrapping="Wrap" />
            <TextBlock b:LoreTextLinks.Text="{Binding Description}"
                       b:LoreTextLinks.Entries="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreEntries}"
                       b:LoreTextLinks.Command="{Binding #Root.((vm:KilleropediaViewModel)DataContext).NavigateLoreCommand}"
                       b:LoreTextLinks.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                       b:LoreTextLinks.CurrentEntryId="{Binding #Root.((vm:KilleropediaViewModel)DataContext).SelectedLoreEntry.Id}"
                       IsVisible="{Binding HasDescription}"
                       TextWrapping="Wrap" />

            <Border Classes="mud-inset" Padding="10" IsVisible="{Binding HasTruth}">
              <TextBlock b:LoreTextLinks.Text="{Binding TruthText}"
                         b:LoreTextLinks.Entries="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreEntries}"
                         b:LoreTextLinks.Command="{Binding #Root.((vm:KilleropediaViewModel)DataContext).NavigateLoreCommand}"
                         b:LoreTextLinks.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                         b:LoreTextLinks.CurrentEntryId="{Binding #Root.((vm:KilleropediaViewModel)DataContext).SelectedLoreEntry.Id}"
                         TextWrapping="Wrap" />
            </Border>
            <TextBlock Classes="mud-faint"
                       b:SearchHighlight.Text="{Binding TimeText, StringFormat='Czas: {0}'}"
                       b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                       IsVisible="{Binding HasTime}" />

            <ItemsControl ItemsSource="{Binding Sections}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:LoreSection">
                  <StackPanel Spacing="5" Margin="0,4">
                    <TextBlock Classes="mud-heading"
                               b:SearchHighlight.Text="{Binding Title}"
                               b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}" />
                    <TextBlock b:LoreTextLinks.Text="{Binding Content}"
                               b:LoreTextLinks.Entries="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreEntries}"
                               b:LoreTextLinks.Command="{Binding #Root.((vm:KilleropediaViewModel)DataContext).NavigateLoreCommand}"
                               b:LoreTextLinks.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                               b:LoreTextLinks.CurrentEntryId="{Binding #Root.((vm:KilleropediaViewModel)DataContext).SelectedLoreEntry.Id}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Spacing="6" IsVisible="{Binding Facts.Count}">
              <TextBlock Classes="mud-heading" Text="FAKTY" />
              <ItemsControl ItemsSource="{Binding Facts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:LoreFact">
                    <Border Classes="mud-inset" Padding="9,6" Margin="0,1">
                      <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   b:SearchHighlight.Text="{Binding Label}"
                                   b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}" />
                        <TextBlock b:LoreTextLinks.Text="{Binding ValueText}"
                                   b:LoreTextLinks.Entries="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreEntries}"
                                   b:LoreTextLinks.Command="{Binding #Root.((vm:KilleropediaViewModel)DataContext).NavigateLoreCommand}"
                                   b:LoreTextLinks.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                                   b:LoreTextLinks.CurrentEntryId="{Binding #Root.((vm:KilleropediaViewModel)DataContext).SelectedLoreEntry.Id}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="mud-faint"
                                   b:SearchHighlight.Text="{Binding QualifierText}"
                                   b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding Links.Count}">
              <TextBlock Classes="mud-heading" Text="POWIĄZANIA" />
              <ItemsControl ItemsSource="{Binding Links}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:LoreLink">
                    <Button Command="{Binding #Root.((vm:KilleropediaViewModel)DataContext).NavigateLoreCommand}"
                            CommandParameter="{Binding}"
                            HorizontalContentAlignment="Stretch"
                            Padding="10,7"
                            Margin="0,1">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" FontWeight="SemiBold"
                                   b:SearchHighlight.Text="{Binding TargetName}"
                                   b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}" />
                        <TextBlock Grid.Column="1" Classes="mud-faint"
                                   b:SearchHighlight.Text="{Binding RelationText}"
                                   b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}" />
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="5" IsVisible="{Binding HasMapReferences}">
              <TextBlock Classes="mud-heading" Text="W ŚWIECIE GRY" />
              <TextBlock b:SearchHighlight.Text="{Binding MapText}"
                         b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="5" IsVisible="{Binding Sources.Count}">
              <TextBlock Classes="mud-heading" Text="ŹRÓDŁA" />
              <ItemsControl ItemsSource="{Binding Sources}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:LoreSourceReference">
                    <TextBlock Classes="mud-faint"
                               b:SearchHighlight.Text="{Binding DisplayText}"
                               b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                               TextWrapping="Wrap" Margin="0,1" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>

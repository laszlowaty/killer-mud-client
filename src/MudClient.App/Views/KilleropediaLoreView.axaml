<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:models="using:MudClient.App.Models"
             xmlns:b="using:MudClient.App.Behaviors"
             x:Class="MudClient.App.Views.KilleropediaLoreView"
             x:DataType="vm:KilleropediaViewModel"
             x:Name="Root">
  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
    <Grid Grid.Row="0" ColumnDefinitions="*,190,Auto" ColumnSpacing="10">
      <TextBox Grid.Column="0"
               Text="{Binding LoreSearchText, UpdateSourceTrigger=PropertyChanged}"
               PlaceholderText="Szukaj miejsca, postaci, wydarzenia, legendy lub wierzenia..." />
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding AvailableLoreCategories}"
                SelectedItem="{Binding SelectedLoreCategory}" />
      <TextBlock Grid.Column="2"
                 Classes="mud-faint"
                 Text="{Binding FilteredLoreCountText}"
                 VerticalAlignment="Center" />
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
      <TextBlock Grid.Column="0"
                 Classes="mud-faint"
                 Text="{Binding LoreCatalogWarning}"
                 IsVisible="{Binding HasLoreCatalogWarning}"
                 TextTrimming="CharacterEllipsis" />
      <TextBlock Grid.Column="1"
                 Classes="mud-faint"
                 Text="{Binding LoreCatalogStatusText}" />
    </Grid>

    <Border Grid.Row="2"
            Classes="mud-section"
            Padding="18"
            IsVisible="{Binding HasNoLoreResults}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <TextBlock Classes="mud-heading-lg" Text="Brak pasujących haseł" HorizontalAlignment="Center" />
        <TextBlock Classes="mud-muted"
                   Text="Zmień wyszukiwaną frazę albo wybierz inną kategorię."
                   TextWrapping="Wrap"
                   TextAlignment="Center" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="2"
          ColumnDefinitions="36*,8,64*"
          IsVisible="{Binding !HasNoLoreResults}">
      <Border Grid.Column="0" Classes="mud-inset" Padding="6">
        <ListBox ItemsSource="{Binding FilteredLoreEntries}"
                 SelectedItem="{Binding SelectedLoreEntry}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:LoreEntry">
              <Border Padding="10,7" Margin="0,1" CornerRadius="3">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Row="0" Grid.Column="0"
                             b:SearchHighlight.Text="{Binding Name}"
                             b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Classes="mud-faint"
                             Text="{Binding Category}" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                             Classes="mud-faint"
                             b:SearchHighlight.Text="{Binding Summary}"
                             b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <GridSplitter Grid.Column="1" ResizeDirection="Columns" />

      <Border Grid.Column="2" Classes="mud-section" Padding="16">
        <ScrollViewer Classes="killeropedia-content-scroll">
          <StackPanel Spacing="12" DataContext="{Binding SelectedLoreEntry}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock Grid.Column="0" Classes="mud-heading-lg" Text="{Binding Name}" TextWrapping="Wrap" />
              <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock Classes="mud-faint" Text="{Binding KindText}" HorizontalAlignment="Right" />
                <TextBlock Classes="mud-faint" Text="{Binding StatusText}" HorizontalAlignment="Right" />
              </StackPanel>
            </Grid>

            <TextBlock Classes="mud-muted"
                       Text="{Binding AliasesText, StringFormat='Znane także jako: {0}'}"
                       IsVisible="{Binding HasAliases}"
                       TextWrapping="Wrap" />
            <TextBlock FontSize="15"
                       b:SearchHighlight.Text="{Binding Summary}"
                       b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                       TextWrapping="Wrap" />
            <TextBlock b:SearchHighlight.Text="{Binding Description}"
                       b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).LoreSearchText}"
                       IsVisible="{Binding HasDescription}"
                       TextWrapping="Wrap" />

            <Border Classes="mud-inset" Padding="10" IsVisible="{Binding HasTruth}">
              <TextBlock Text="{Binding TruthText}" TextWrapping="Wrap" />
            </Border>
            <TextBlock Classes="mud-faint"
                       Text="{Binding TimeText, StringFormat='Czas: {0}'}"
                       IsVisible="{Binding HasTime}" />

            <ItemsControl ItemsSource="{Binding Sections}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:LoreSection">
                  <StackPanel Spacing="5" Margin="0,4">
                    <TextBlock Classes="mud-heading" Text="{Binding Title}" />
                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Spacing="6" IsVisible="{Binding Facts.Count}">
              <TextBlock Classes="mud-heading" Text="FAKTY" />
              <ItemsControl ItemsSource="{Binding Facts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:LoreFact">
                    <Border Classes="mud-inset" Padding="9,6" Margin="0,1">
                      <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                        <TextBlock Text="{Binding ValueText}" TextWrapping="Wrap" />
                        <TextBlock Classes="mud-faint" Text="{Binding QualifierText}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding Links.Count}">
              <TextBlock Classes="mud-heading" Text="POWIĄZANIA" />
              <ItemsControl ItemsSource="{Binding Links}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:LoreLink">
                    <Button Command="{Binding #Root.((vm:KilleropediaViewModel)DataContext).NavigateLoreCommand}"
                            CommandParameter="{Binding}"
                            HorizontalContentAlignment="Stretch"
                            Padding="10,7"
                            Margin="0,1">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="{Binding TargetName}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Classes="mud-faint" Text="{Binding RelationText}" />
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="5" IsVisible="{Binding HasMapReferences}">
              <TextBlock Classes="mud-heading" Text="W ŚWIECIE GRY" />
              <TextBlock Text="{Binding MapText}" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="5" IsVisible="{Binding Sources.Count}">
              <TextBlock Classes="mud-heading" Text="ŹRÓDŁA" />
              <ItemsControl ItemsSource="{Binding Sources}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:LoreSourceReference">
                    <TextBlock Classes="mud-faint" Text="{Binding DisplayText}" TextWrapping="Wrap" Margin="0,1" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>

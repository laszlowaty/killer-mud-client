<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:models="using:MudClient.App.Models"
             xmlns:b="using:MudClient.App.Behaviors"
             x:Class="MudClient.App.Views.KilleropediaTeachersView"
             x:DataType="vm:KilleropediaViewModel"
             x:Name="Root">
  <Grid RowDefinitions="Auto,*" RowSpacing="10">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
      <TextBox Grid.Column="0"
               Text="{Binding TeacherSearchText, UpdateSourceTrigger=PropertyChanged}"
               PlaceholderText="Szukaj po nauczycielu, umiejętności, triku, klasie, krainie lub vnum..." />
      <TextBlock Grid.Column="1"
                 Classes="mud-faint"
                 Text="{Binding FilteredTeacherCountText}"
                 VerticalAlignment="Center" />
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="36*,8,64*">
      <Border Grid.Column="0" Classes="mud-inset" Padding="6">
        <ListBox ItemsSource="{Binding FilteredTeachers}"
                 SelectedItem="{Binding SelectedTeacher}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:TeacherEntry">
              <Border Padding="10,7" Margin="0,1" CornerRadius="3">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBlock Grid.Row="0" Grid.Column="0"
                             b:SearchHighlight.Text="{Binding Name}"
                             b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).TeacherSearchText}"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Classes="mud-faint"
                             Text="{Binding MobVnum, StringFormat='mob {0}'}" />
                  <TextBlock Grid.Row="1" Grid.Column="0"
                             Classes="mud-faint"
                             b:SearchHighlight.Text="{Binding LocationText}"
                             b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).TeacherSearchText}"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Row="1" Grid.Column="1"
                             Classes="mud-faint"
                             Text="{Binding OfferingCountText}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <GridSplitter Grid.Column="1" ResizeDirection="Columns" />

      <Border Grid.Column="2" Classes="mud-section" Padding="16">
        <ScrollViewer Classes="killeropedia-content-scroll">
          <StackPanel Spacing="12" DataContext="{Binding SelectedTeacher}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Grid.Column="0" Spacing="3">
                <TextBlock Classes="mud-heading-lg" Text="{Binding Name}" />
                <TextBlock Classes="mud-muted" Text="{Binding RegionText}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="7" HorizontalAlignment="Right">
                <TextBlock Classes="mud-faint" Text="{Binding MobVnum, StringFormat='Mob vnum: {0}'}" />
                <TextBlock Classes="mud-faint" Text="{Binding RoomText, StringFormat='Pokój vnum: {0}'}" />
                <Button Content="Pokaż na mapie"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding HasRoomLocation}"
                        Command="{Binding $parent[UserControl].DataContext.ShowTeacherOnMapCommand}"
                        CommandParameter="{Binding}" />
              </StackPanel>
            </Grid>

            <Border Classes="mud-inset" Padding="10">
              <StackPanel Spacing="4">
                <TextBlock Classes="mud-heading" Text="KLASY" />
                <TextBlock b:SearchHighlight.Text="{Binding ClassesText}"
                           b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).TeacherSearchText}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <TabControl x:Name="TeacherOfferingTabs" Classes="mud-subtabs">
              <TabItem Header="Umiejętności">
                <StackPanel Spacing="6" Margin="0,8,0,0">
                  <Grid ColumnDefinitions="2*,80,70,80" ColumnSpacing="8" Margin="8,0">
                    <TextBlock Grid.Column="0" Classes="mud-faint" Text="Nazwa" />
                    <TextBlock Grid.Column="1" Classes="mud-faint" Text="Zakres" />
                    <TextBlock Grid.Column="2" Classes="mud-faint" Text="Cena" />
                    <TextBlock Grid.Column="3" Classes="mud-faint" Text="Wymaga" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding Skills}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="models:TeacherSkillEntry">
                        <Border Classes="mud-inset" Padding="8,6" Margin="0,1">
                          <Grid ColumnDefinitions="2*,80,70,80" ColumnSpacing="8">
                            <TextBlock Grid.Column="0"
                                       b:SearchHighlight.Text="{Binding Name}"
                                       b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).TeacherSearchText}" />
                            <TextBlock Grid.Column="1" Text="{Binding RangeText}" />
                            <TextBlock Grid.Column="2" Text="{Binding PriceText}" />
                            <TextBlock Grid.Column="3" Text="{Binding RequirementText}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </TabItem>

              <TabItem Header="Triki">
                <StackPanel Spacing="6" Margin="0,8,0,0">
                  <Grid ColumnDefinitions="*,120,100" ColumnSpacing="8" Margin="8,0">
                    <TextBlock Grid.Column="0" Classes="mud-faint" Text="Nazwa" />
                    <TextBlock Grid.Column="1" Classes="mud-faint" Text="Szansa nauki" />
                    <TextBlock Grid.Column="2" Classes="mud-faint" Text="Cena" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding Tricks}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="models:TeacherTrickEntry">
                        <Border Classes="mud-inset" Padding="8,6" Margin="0,1">
                          <Grid ColumnDefinitions="*,120,100" ColumnSpacing="8">
                            <TextBlock Grid.Column="0"
                                       b:SearchHighlight.Text="{Binding Name}"
                                       b:SearchHighlight.Terms="{Binding #Root.((vm:KilleropediaViewModel)DataContext).TeacherSearchText}" />
                            <TextBlock Grid.Column="1" Text="{Binding LearnChanceText}" />
                            <TextBlock Grid.Column="2" Text="{Binding PriceText}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </TabItem>
            </TabControl>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>

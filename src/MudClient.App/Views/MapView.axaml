<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:MudClient.App.Controls"
             xmlns:vm="using:MudClient.App.ViewModels"
             xmlns:map="using:MudClient.Core.Map"
             x:Class="MudClient.App.Views.MapView"
             x:Name="Root"
             x:DataType="vm:MapViewModel">
  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ========================================================================
         Header bar: area / Z selector + toolbar
         ======================================================================== -->
    <Border Grid.Row="0" Classes="mud-bar" Padding="10,6">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">

        <TextBlock Grid.Column="0" Classes="mud-heading" Text="OBSZAR" VerticalAlignment="Center" />
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding Areas}"
                  SelectedItem="{Binding SelectedArea}"
                  MinWidth="150">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="map:MapArea">
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Grid.Column="2" Classes="mud-heading" Text="POZIOM Z" VerticalAlignment="Center" />
        <ComboBox Grid.Column="3"
                  ItemsSource="{Binding ZLevels}"
                  SelectedItem="{Binding SelectedZ}"
                  MinWidth="70" />

        <ToggleButton Grid.Column="4"
                      Content="Śledź"
                      IsChecked="{Binding FollowPlayer}"
                      Padding="8,4" FontSize="11" />

        <!-- Toolbar buttons -->
        <StackPanel Grid.Column="6"
                    Orientation="Horizontal" Spacing="4"
                    HorizontalAlignment="Right">
          <Button Content="Wycentruj"
                  Command="{Binding CenterCommand}"
                  Padding="10,5" FontSize="11" />
          <Button Content="Reset zoom"
                  Command="{Binding ResetZoomCommand}"
                  Padding="10,5" FontSize="11" />
        </StackPanel>

        <!-- Current room info -->
        <Border Grid.Column="7"
                Background="{StaticResource MudBrushStone}"
                CornerRadius="3" Padding="6,3">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Classes="mud-faint" Text="VNUM:" />
            <TextBlock Classes="mud-status-info" Text="{Binding CurrentVnum}" />
          </StackPanel>
        </Border>

        <Border Grid.Column="8"
                Background="{StaticResource MudBrushStone}"
                CornerRadius="3" Padding="6,3">
          <TextBlock Text="{Binding CurrentRoomName}" MaxWidth="120"
                     TextTrimming="CharacterEllipsis" />
        </Border>

        <Border Grid.Column="9"
                Background="{StaticResource MudBrushStone}"
                CornerRadius="3" Padding="6,3">
          <TextBlock Classes="mud-muted" Text="{Binding CurrentSectorName}" />
        </Border>

      </Grid>
    </Border>

    <!-- ========================================================================
          Map content area: map control on top, resizable room details below
          ======================================================================== -->
    <Grid Grid.Row="1" RowDefinitions="*,Auto,220">

      <!-- Map control -->
      <Border Grid.Row="0" Background="Black">
        <Panel>
          <controls:WorldMapControl x:Name="MapControl" />

          <!-- Loading overlay -->
          <Border Background="#CC101010"
                  IsVisible="{Binding IsLoading}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Padding="20,12"
                  CornerRadius="6">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" />
          </Border>

          <!-- Error overlay -->
          <Border Background="#CC401010"
                  IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Margin="0,12,0,0"
                  Padding="16,10"
                  CornerRadius="6">
            <StackPanel Spacing="6">
              <SelectableTextBlock Text="{Binding ErrorMessage}"
                                    Foreground="White"
                                    TextWrapping="Wrap"
                                    MaxWidth="480" />
              <Button Content="Spróbuj ponownie"
                      Command="{Binding ReloadCommand}"
                      HorizontalAlignment="Left"
                      Padding="12,6" />
            </StackPanel>
          </Border>
        </Panel>
      </Border>

      <!-- Vertical splitter between map and details -->
      <GridSplitter Grid.Row="1"
                    Height="6"
                    HorizontalAlignment="Stretch"
                    ResizeDirection="Rows"
                    Background="{StaticResource MudBrushStone}" />

      <!-- Room details panel -->
      <Border Grid.Row="2"
              Classes="mud-panel"
              Margin="0,6,0,0"
              Padding="12">
        <Grid ColumnDefinitions="*,Auto">
          <!-- Left: details -->
          <StackPanel Spacing="8">
            <TextBlock Classes="mud-heading" Text="SZCZEGÓŁY POKOJU" />

            <Border Background="{StaticResource MudBrushVoid}"
                    CornerRadius="3" Padding="8">
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Classes="mud-muted" Text="Id:" />
                  <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding SelectedRoom.Id}" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Classes="mud-muted" Text="Nazwa:" />
                  <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                             Text="{Binding SelectedRoom.Name}"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Classes="mud-muted" Text="Vnum:" />
                  <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding SelectedRoom.Vnum}" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Classes="mud-muted" Text="Sektor:" />
                  <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding SelectedRoom.Sector}" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Classes="mud-muted" Text="Środowisko:" />
                  <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                             Text="{Binding SelectedRoom.Environment}"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Classes="mud-muted" Text="Waga:" />
                  <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding SelectedRoom.Weight}" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Right: square room image -->
          <Border Grid.Column="1"
                  Background="{StaticResource MudBrushVoid}"
                  BorderBrush="{StaticResource MudBrushGoldDim}"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="6"
                  Margin="12,0,0,0"
                  Width="170"
                  Height="170"
                  VerticalAlignment="Top">
            <Image Source="{Binding SelectedRoomIcon}"
                   Stretch="Uniform"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center" />
          </Border>
        </Grid>
      </Border>

    </Grid>

    <!-- ========================================================================
         Footer bar: status message
         ======================================================================== -->
    <Border Grid.Row="2" Classes="mud-bar-bottom" Padding="10,5">
      <TextBlock Classes="mud-faint" Text="{Binding StatusMessage}" />
    </Border>

  </Grid>
</UserControl>

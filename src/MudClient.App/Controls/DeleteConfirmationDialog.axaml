<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MudClient.App.Controls.DeleteConfirmationDialog"
        Title="Potwierdzenie usunięcia"
        Width="440"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
  <Border Padding="20">
    <StackPanel Spacing="14">
      <TextBlock Text="Potwierdź usunięcie"
                 FontSize="18"
                 FontWeight="SemiBold" />
      <TextBlock x:Name="PromptText"
                 TextWrapping="Wrap" />
      <TextBlock Text="Tej operacji nie można cofnąć."
                 Classes="mud-faint"
                 TextWrapping="Wrap" />
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="8">
        <Button x:Name="CancelButton"
                Content="Anuluj"
                IsCancel="True"
                Click="Cancel_OnClick" />
        <Button Content="Usuń"
                Classes="mud-danger"
                IsDefault="True"
                Click="Delete_OnClick" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>

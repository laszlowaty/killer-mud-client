<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MudClient.App.Controls.MudOutputView">
  <Border Classes="mud-inset" Padding="8">
    <Border.ContextMenu>
      <ContextMenu>
        <MenuItem Header="Kopiuj zaznaczenie" Click="CopySelection_OnClick" />
        <MenuItem Header="Kopiuj cały bufor" Click="CopyAll_OnClick" />
        <Separator />
        <MenuItem Header="Wyczyść ekran" Click="ClearOutput_OnClick" />
      </ContextMenu>
    </Border.ContextMenu>
    <Grid x:Name="OutputGrid" RowDefinitions="*,Auto,0">
      <!-- Upper pane: scrollback buffer (manual scroll). Content is an OutputPaneControl
           created in code-behind; it virtualizes rendering via ILogicalScrollable. -->
      <ScrollViewer Grid.Row="0"
                    x:Name="ScrollbackScroller"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto" />

      <!-- GridSplitter between panes -->
      <GridSplitter Grid.Row="1"
                    x:Name="OutputSplitter"
                    Height="6"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource MudBrushStone}" />

      <!-- Lower pane: live tail (auto-scroll) -->
      <ScrollViewer Grid.Row="2"
                    x:Name="LiveTailScroller"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto" />
    </Grid>
  </Border>
</UserControl>

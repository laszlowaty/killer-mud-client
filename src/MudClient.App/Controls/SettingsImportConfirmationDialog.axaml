<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MudClient.App.Controls.SettingsImportConfirmationDialog"
        Title="Import ustawień"
        Width="500"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
  <Border Padding="20">
    <StackPanel Spacing="14">
      <TextBlock Text="Nadpisać wszystkie ustawienia?"
                 FontSize="18"
                 FontWeight="SemiBold" />
      <TextBlock Text="Import zastąpi cały katalog danych aplikacji: ustawienia, profile, automatyzację, zapisany układ i pozostałe dane."
                 TextWrapping="Wrap" />
      <TextBlock Text="Po przygotowaniu importu aplikacja automatycznie uruchomi się ponownie i wczyta wybraną kopię."
                 Classes="mud-faint"
                 TextWrapping="Wrap" />
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="8">
        <Button x:Name="CancelButton"
                Content="Anuluj"
                IsCancel="True"
                Click="Cancel_OnClick" />
        <Button Content="Importuj i uruchom ponownie"
                Classes="mud-danger"
                IsDefault="True"
                Click="Import_OnClick" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>

<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Button">
    <Setter Property="Background" Value="{StaticResource MudBrushButtonGradient}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushGoldBright}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="14,7" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource MudBrushButtonGradientHover}" />
    <Setter Property="TextBlock.Foreground" Value="{StaticResource MudColorGoldBright}" />
  </Style>
  <Style Selector="Button:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGold}" />
  </Style>
  <Style Selector="Button:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource MudBrushButtonGradientPressed}" />
    <Setter Property="TextBlock.Foreground" Value="{StaticResource MudColorGoldBright}" />
  </Style>
  <Style Selector="Button:focus-visible">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldBright}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>
  <Style Selector="Button:disabled /template/ ContentPresenter">
    <Setter Property="Opacity" Value="0.5" />
  </Style>

  <Style Selector="Button.mud-danger">
    <Setter Property="Background" Value="{StaticResource MudBrushDangerButtonGradient}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushCrimsonBright}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushCrimson}" />
  </Style>
  <Style Selector="Button.mud-danger:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource MudBrushDangerButtonGradientHover}" />
    <Setter Property="TextBlock.Foreground" Value="{StaticResource MudColorCrimsonBright}" />
  </Style>
  <Style Selector="Button.mud-danger:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushCrimsonBright}" />
  </Style>

  <Style Selector="Button.mud-small">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Padding" Value="8,4" />
  </Style>

  <Style Selector="Button.mud-menu-action">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Padding" Value="8,5" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>
  <Style Selector="Button.mud-menu-action:pointerover">
    <Setter Property="Background" Value="{StaticResource MudBrushStoneLight}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchment}" />
  </Style>

  <Style Selector="Button.mud-notice">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="Padding" Value="7,3" />
    <Setter Property="Background" Value="{StaticResource MudBrushStoneLight}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushGold}" />
  </Style>
  <Style Selector="Button.mud-notice-success">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushEmerald}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushEmeraldBright}" />
  </Style>

  <Style Selector="Button.mud-chip">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Background" Value="{StaticResource MudBrushStone}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlate}" />
  </Style>
  <Style Selector="Button.mud-chip:pointerover">
    <Setter Property="Foreground" Value="{StaticResource MudBrushGold}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
  </Style>

  <Style Selector="ToggleButton.mud-chip">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Background" Value="{StaticResource MudBrushStoneLight}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushArcaneBlueBright}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlateLight}" />
  </Style>
  <Style Selector="ToggleButton.mud-chip:checked">
    <Setter Property="Foreground" Value="{StaticResource MudBrushGoldBright}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGold}" />
  </Style>

  <!-- On/off switch pill: red-ish when off, green when on -->
  <Style Selector="ToggleButton.mud-switch">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Padding" Value="9,3" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Background" Value="{StaticResource MudBrushStoneLight}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentFaint}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlateLight}" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="ToggleButton.mud-switch:checked">
    <Setter Property="Foreground" Value="{StaticResource MudBrushEmeraldBright}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushEmerald}" />
  </Style>
  <Style Selector="ToggleButton.mud-switch:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource MudBrushStoneLight}" />
    <Setter Property="TextBlock.Foreground" Value="{StaticResource MudBrushEmeraldBright}" />
  </Style>

</Styles>

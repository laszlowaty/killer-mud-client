<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="using:Dock.Avalonia.Controls"
        xmlns:dockSettings="using:Dock.Settings"
        xmlns:psp="using:Dock.Controls.ProportionalStackPanel"
        xmlns:panels="using:MudClient.App.Views.Panels">
  <!--
    Light-touch theming so Dock.Avalonia's chrome (tab strips, tool headers,
    splitters) blends with the fantasy palette instead of the default Fluent look.
  -->
  <Styles.Resources>
    <!-- The three-dot menu belongs to the active widget's ToolDock. Runtime bindings are
         intentional: ActiveDockable is declared as IDockable but is a PanelTool here. -->
    <MenuFlyout x:Key="MudToolFlyout" x:CompileBindings="False">
      <MenuItem Header="Wróć do układu" Command="{Binding ActiveDockable.ReturnToLayoutCommand}" />
      <Separator />
      <MenuItem Header="Przypnij z lewej" Command="{Binding ActiveDockable.PinLeftCommand}" />
      <MenuItem Header="Przypnij z prawej" Command="{Binding ActiveDockable.PinRightCommand}" />
      <MenuItem Header="Przypnij u góry" Command="{Binding ActiveDockable.PinTopCommand}" />
      <MenuItem Header="Przypnij u dołu" Command="{Binding ActiveDockable.PinBottomCommand}" />
      <Separator />
      <MenuItem Header="Zamknij"
                Command="{Binding Owner.Factory.CloseDockable}"
                CommandParameter="{Binding ActiveDockable}" />
    </MenuFlyout>

    <!--
      Hides the chrome's built-in pin/auto-hide button. Its single click chooses the owner
      dock's edge instead of the edge explicitly selected in the panel menu. CanPin must stay
      true (PinDockable no-ops otherwise), so we blank the button:
      empty template + zero size + no hit-testing.
    -->
    <ControlTheme x:Key="MudHiddenPinButton" TargetType="Button">
      <Setter Property="IsVisible" Value="False" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Width" Value="0" />
      <Setter Property="Height" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Panel />
        </ControlTemplate>
      </Setter>
    </ControlTheme>
  </Styles.Resources>

  <Style Selector="dock|ToolChromeControl">
    <Setter Property="Background" Value="{StaticResource MudBrushStone}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
    <Setter Property="PinButtonTheme" Value="{StaticResource MudHiddenPinButton}" />
    <Setter Property="ToolFlyout" Value="{DynamicResource MudToolFlyout}" />
  </Style>

  <!-- Expanded auto-hide previews must not enter Dock 12's drag pipeline. Dragging that
       temporary ToolDock can leave both the original pinned item and a split wrapper. -->
  <Style Selector="dock|ToolChromeControl:pinned">
    <Setter Property="(dockSettings:DockProperties.IsDragEnabled)" Value="False" />
  </Style>

  <Style Selector="dock|DocumentTabStripItem, dock|ToolTabStripItem">
    <Setter Property="Background" Value="{StaticResource MudBrushStone}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
  </Style>

  <Style Selector="dock|DocumentTabStripItem:selected, dock|ToolTabStripItem:selected">
    <Setter Property="Background" Value="{StaticResource MudBrushSlate}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushGoldBright}" />
  </Style>

  <Style Selector="psp|ProportionalStackPanelSplitter">
    <Setter Property="Background" Value="{StaticResource MudBrushStone}" />
  </Style>

  <!--
    Styles/Buttons.axaml defines a global "Button" style (fantasy-themed padding/
    background/border) that also matches the tiny close/pin/maximize/menu buttons
    inside Dock's tool chrome, squeezing their icon glyphs down to nothing. Give
    those controls an explicit compact size so the icons stay visible without
    letting every widget header dominate its content.
  -->
  <Style Selector="dock|ToolChromeControl /template/ Button">
    <Setter Property="Padding" Value="2" />
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="14" />
    <Setter Property="Margin" Value="1,0,0,0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
  </Style>

  <Style Selector="dock|ToolChromeControl /template/ TextBlock#PART_Title">
    <Setter Property="Margin" Value="0,0,6,0" />
  </Style>

  <Style Selector="dock|ToolChromeControl /template/ Border#PART_Border">
    <Setter Property="Height" Value="20" />
  </Style>

  <Style Selector="dock|ToolChromeControl /template/ Button:pointerover">
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushGoldBright}" />
  </Style>

  <!-- Names of docked widgets use the same typography as their contents. -->
  <Style Selector="dock|ToolTabStripItem">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>

  <!-- The title of an auto-hidden widget is rendered by a separate edge-tab control. -->
  <Style Selector="dock|ToolPinItemControl">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>

  <!--
    PanelToolView also lives below ToolChromeControl, so restore the application button
    chrome inside widget content after the narrow Dock chrome override above.
  -->
  <Style Selector="UserControl.mud-widget-content Button">
    <Setter Property="Padding" Value="14,7" />
    <Setter Property="Background" Value="{StaticResource MudBrushButtonGradient}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushGoldBright}" />
  </Style>

  <!-- Widget typography must be applied to the text-producing controls themselves.
       Setting it only on PanelToolView is insufficient: application styles for headings,
       inputs and buttons otherwise override the inherited value. The terminal deliberately
       does not receive mud-configurable-widget. -->
  <Style Selector="panels|PanelToolView.mud-configurable-widget TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>
  <Style Selector="panels|PanelToolView.mud-configurable-widget SelectableTextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>
  <Style Selector="panels|PanelToolView.mud-configurable-widget TextBox">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>
  <Style Selector="panels|PanelToolView.mud-configurable-widget Button">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>
  <Style Selector="panels|PanelToolView.mud-configurable-widget ToggleButton">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>
  <Style Selector="panels|PanelToolView.mud-configurable-widget ComboBox">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>
  <Style Selector="panels|PanelToolView.mud-configurable-widget CheckBox">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>
  <Style Selector="panels|PanelToolView.mud-configurable-widget Expander">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>
  <Style Selector="panels|PanelToolView.mud-configurable-widget TabItem">
    <Setter Property="FontFamily" Value="{DynamicResource WidgetFontFamilyResource}" />
    <Setter Property="FontSize" Value="{DynamicResource WidgetFontSizeResource}" />
    <Setter Property="FontWeight" Value="{DynamicResource WidgetFontWeightResource}" />
  </Style>
  <Style Selector="UserControl.mud-widget-content Button:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGold}" />
  </Style>
  <Style Selector="UserControl.mud-widget-content Button.mud-small">
    <Setter Property="Padding" Value="8,4" />
  </Style>
  <Style Selector="UserControl.mud-widget-content Button.mud-chip">
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Background" Value="{StaticResource MudBrushStone}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlate}" />
  </Style>
  <Style Selector="UserControl.mud-widget-content Button.mud-chip:pointerover">
    <Setter Property="Foreground" Value="{StaticResource MudBrushGold}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
  </Style>
  <Style Selector="UserControl.mud-widget-content Button.mud-danger">
    <Setter Property="Background" Value="{StaticResource MudBrushDangerButtonGradient}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushCrimsonBright}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushCrimson}" />
  </Style>
  <Style Selector="UserControl.mud-widget-content Button.mud-danger:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushCrimsonBright}" />
  </Style>
</Styles>

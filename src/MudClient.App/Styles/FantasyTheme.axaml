<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Fantasy MUD theme: dark wood / stone backdrop, aged parchment text,
    candle-gold accents, arcane emerald + blood-crimson for status.
    Every color and control look lives here so views only reference
    brushes / style classes, never raw hex values.
  -->

  <Styles.Resources>
    <ResourceDictionary>

      <!-- ===== Palette ===== -->
      <Color x:Key="MudColorVoid">#0A0C10</Color>
      <Color x:Key="MudColorAbyss">#0E1015</Color>
      <Color x:Key="MudColorStone">#171A21</Color>
      <Color x:Key="MudColorStoneLight">#20242E</Color>
      <Color x:Key="MudColorSlate">#2A2F3B</Color>
      <Color x:Key="MudColorSlateLight">#3A4152</Color>

      <Color x:Key="MudColorGold">#C9A24B</Color>
      <Color x:Key="MudColorGoldBright">#E8C878</Color>
      <Color x:Key="MudColorGoldDim">#8A7238</Color>

      <Color x:Key="MudColorParchment">#E8DFC8</Color>
      <Color x:Key="MudColorParchmentDim">#A79E8C</Color>
      <Color x:Key="MudColorParchmentFaint">#6B6558</Color>

      <Color x:Key="MudColorEmerald">#4E9A6B</Color>
      <Color x:Key="MudColorEmeraldBright">#6FC98F</Color>
      <Color x:Key="MudColorCrimson">#B04A4A</Color>
      <Color x:Key="MudColorCrimsonBright">#E36A6A</Color>
      <Color x:Key="MudColorArcaneBlue">#5E8FC9</Color>
      <Color x:Key="MudColorArcaneBlueBright">#7FB0EA</Color>
      <Color x:Key="MudColorAmberWarn">#D9922E</Color>

      <!-- ===== Brushes ===== -->
      <SolidColorBrush x:Key="MudBrushVoid" Color="{StaticResource MudColorVoid}" />
      <SolidColorBrush x:Key="MudBrushAbyss" Color="{StaticResource MudColorAbyss}" />
      <SolidColorBrush x:Key="MudBrushStone" Color="{StaticResource MudColorStone}" />
      <SolidColorBrush x:Key="MudBrushStoneLight" Color="{StaticResource MudColorStoneLight}" />
      <SolidColorBrush x:Key="MudBrushSlate" Color="{StaticResource MudColorSlate}" />
      <SolidColorBrush x:Key="MudBrushSlateLight" Color="{StaticResource MudColorSlateLight}" />

      <SolidColorBrush x:Key="MudBrushGold" Color="{StaticResource MudColorGold}" />
      <SolidColorBrush x:Key="MudBrushGoldBright" Color="{StaticResource MudColorGoldBright}" />
      <SolidColorBrush x:Key="MudBrushGoldDim" Color="{StaticResource MudColorGoldDim}" />

      <SolidColorBrush x:Key="MudBrushParchment" Color="{StaticResource MudColorParchment}" />
      <SolidColorBrush x:Key="MudBrushParchmentDim" Color="{StaticResource MudColorParchmentDim}" />
      <SolidColorBrush x:Key="MudBrushParchmentFaint" Color="{StaticResource MudColorParchmentFaint}" />

      <SolidColorBrush x:Key="MudBrushEmerald" Color="{StaticResource MudColorEmerald}" />
      <SolidColorBrush x:Key="MudBrushEmeraldBright" Color="{StaticResource MudColorEmeraldBright}" />
      <SolidColorBrush x:Key="MudBrushCrimson" Color="{StaticResource MudColorCrimson}" />
      <SolidColorBrush x:Key="MudBrushCrimsonBright" Color="{StaticResource MudColorCrimsonBright}" />
      <SolidColorBrush x:Key="MudBrushArcaneBlue" Color="{StaticResource MudColorArcaneBlue}" />
      <SolidColorBrush x:Key="MudBrushArcaneBlueBright" Color="{StaticResource MudColorArcaneBlueBright}" />
      <SolidColorBrush x:Key="MudBrushAmberWarn" Color="{StaticResource MudColorAmberWarn}" />

      <LinearGradientBrush x:Key="MudBrushHeaderGradient" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="{StaticResource MudColorStoneLight}" Offset="0" />
        <GradientStop Color="{StaticResource MudColorStone}" Offset="1" />
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="MudBrushButtonGradient" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="{StaticResource MudColorSlateLight}" Offset="0" />
        <GradientStop Color="{StaticResource MudColorSlate}" Offset="1" />
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="MudBrushButtonGradientHover" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="{StaticResource MudColorGoldDim}" Offset="0" />
        <GradientStop Color="{StaticResource MudColorSlate}" Offset="1" />
      </LinearGradientBrush>

    </ResourceDictionary>
  </Styles.Resources>

  <!-- ===== Base ===== -->
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Georgia,Cambria,Times New Roman,serif" />
    <Setter Property="Background" Value="{StaticResource MudBrushVoid}" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchment}" />
  </Style>

  <!-- Section / caption headings, small-caps gold -->
  <Style Selector="TextBlock.mud-heading">
    <Setter Property="Foreground" Value="{StaticResource MudBrushGoldBright}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="LetterSpacing" Value="1" />
  </Style>

  <Style Selector="TextBlock.mud-muted">
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
  </Style>

  <Style Selector="TextBlock.mud-faint">
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentFaint}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="TextBlock.mud-status-ok">
    <Setter Property="Foreground" Value="{StaticResource MudBrushEmeraldBright}" />
  </Style>

  <Style Selector="TextBlock.mud-status-bad">
    <Setter Property="Foreground" Value="{StaticResource MudBrushCrimsonBright}" />
  </Style>

  <!-- ===== Panels / chrome ===== -->
  <Style Selector="Border.mud-panel">
    <Setter Property="Background" Value="{StaticResource MudBrushAbyss}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlate}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="Border.mud-bar">
    <Setter Property="Background" Value="{StaticResource MudBrushHeaderGradient}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style Selector="Border.mud-bar-bottom">
    <Setter Property="Background" Value="{StaticResource MudBrushHeaderGradient}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
  </Style>

  <Style Selector="Border.mud-inset">
    <Setter Property="Background" Value="{StaticResource MudBrushVoid}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
  </Style>

  <!-- ===== Buttons ===== -->
  <Style Selector="Button">
    <Setter Property="Background" Value="{StaticResource MudBrushButtonGradient}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushGoldBright}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="14,7" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource MudBrushButtonGradientHover}" />
    <Setter Property="TextBlock.Foreground" Value="{StaticResource MudColorGoldBright}" />
  </Style>
  <Style Selector="Button:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGold}" />
  </Style>
  <Style Selector="Button:disabled /template/ ContentPresenter">
    <Setter Property="Opacity" Value="0.5" />
  </Style>

  <Style Selector="Button.mud-danger">
    <Setter Property="Foreground" Value="{StaticResource MudBrushCrimsonBright}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushCrimson}" />
  </Style>

  <!-- ===== Inputs ===== -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="{StaticResource MudBrushVoid}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchment}" />
    <Setter Property="CaretBrush" Value="{StaticResource MudBrushGoldBright}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlateLight}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="SelectionBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="Padding" Value="8,6" />
  </Style>
  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGold}" />
  </Style>
  <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentFaint}" />
  </Style>

  <Style Selector="TextBox.terminal-input">
    <Setter Property="FontFamily" Value="Cascadia Code,Consolas,monospace" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="Background" Value="{StaticResource MudBrushAbyss}" />
  </Style>

  <!-- ===== Tabs ===== -->
  <Style Selector="TabControl">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="TabItem">
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="16,10" />
  </Style>
  <Style Selector="TabItem:selected">
    <Setter Property="Foreground" Value="{StaticResource MudBrushGoldBright}" />
  </Style>
  <Style Selector="TabItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGold}" />
  </Style>

  <!-- ===== Lists ===== -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ListBoxItem">
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource MudBrushStoneLight}" />
  </Style>

  <!-- ===== Splitter / scroll ===== -->
  <Style Selector="GridSplitter">
    <Setter Property="Background" Value="{StaticResource MudBrushSlate}" />
  </Style>

  <Style Selector="ScrollBar">
    <Setter Property="Background" Value="Transparent" />
  </Style>

</Styles>

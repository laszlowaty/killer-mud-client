<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="TabControl">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="TabItem">
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="MinHeight" Value="0" />
  </Style>

  <!-- Compact inner tab strip (e.g. GMCP sub-tabs) -->
  <Style Selector="TabControl.mud-subtabs TabItem">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Padding" Value="10,5" />
  </Style>
  <Style Selector="TabItem:selected">
    <Setter Property="Foreground" Value="{StaticResource MudBrushGoldBright}" />
  </Style>
  <Style Selector="TabItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGold}" />
  </Style>

</Styles>

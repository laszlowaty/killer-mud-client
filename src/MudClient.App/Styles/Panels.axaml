<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Border.mud-panel">
    <Setter Property="Background" Value="{StaticResource MudBrushAbyss}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlate}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="Border.mud-bar">
    <Setter Property="Background" Value="{StaticResource MudBrushHeaderGradient}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style Selector="Border.mud-bar-top">
    <Setter Property="Background" Value="{StaticResource MudBrushStone}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlate}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <Style Selector="Border.mud-bar-bottom">
    <Setter Property="Background" Value="{StaticResource MudBrushHeaderGradient}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="10,5" />
  </Style>

  <Style Selector="Border.mud-inset">
    <Setter Property="Background" Value="{StaticResource MudBrushVoid}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
  </Style>

  <Style Selector="Border.mud-section">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlate}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="8,8,8,9" />
  </Style>

  <Style Selector="Border.mud-status-chip">
    <Setter Property="Background" Value="{StaticResource MudBrushStoneLight}" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="7,2" />
  </Style>
  <Style Selector="Border.mud-status-chip > TextBlock">
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="Border.mud-toast">
    <Setter Property="Background" Value="{StaticResource MudBrushStoneLight}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlate}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,5" />
    <Setter Property="Opacity" Value="0.96" />
  </Style>
  <Style Selector="Border.mud-toast TextBlock">
    <Setter Property="FontSize" Value="11" />
  </Style>

  <!-- Folder header row inside the reusable FolderTreeView -->
  <Style Selector="Border.mud-folder-row">
    <Setter Property="Background" Value="{StaticResource MudBrushHeaderGradient}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushGoldDim}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>
  <Style Selector="Border.mud-folder-row.mud-folder-enabled">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushEmerald}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>
  <Style Selector="Border.mud-folder-row.mud-folder-disabled">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushCrimson}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>
  <Style Selector="Border.mud-folder-row.mud-folder-mixed">
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushAmberWarn}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <Style Selector="TextBox.mud-folder-name">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="2,0" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushGold}" />
  </Style>

  <!-- Small rounded label pill, e.g. rule type or interval -->
  <Style Selector="Border.mud-badge">
    <Setter Property="Background" Value="{StaticResource MudBrushSlate}" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.mud-badge > TextBlock">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushParchmentDim}" />
  </Style>
  <Style Selector="Border.mud-badge-gold > TextBlock">
    <Setter Property="Foreground" Value="{StaticResource MudBrushGold}" />
  </Style>
  <Style Selector="Border.mud-badge-green > TextBlock">
    <Setter Property="Foreground" Value="{StaticResource MudBrushEmeraldBright}" />
  </Style>
  <Style Selector="Border.mud-badge-red > TextBlock">
    <Setter Property="Foreground" Value="{StaticResource MudBrushCrimsonBright}" />
  </Style>
  <Style Selector="Border.mud-badge-amber > TextBlock">
    <Setter Property="Foreground" Value="{StaticResource MudBrushAmberWarn}" />
  </Style>

  <!-- Themed expander used for "add new..." forms in the sidebar -->
  <Style Selector="Expander.mud-expander">
    <Setter Property="Background" Value="{StaticResource MudBrushStone}" />
    <Setter Property="BorderBrush" Value="{StaticResource MudBrushSlate}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="10" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>
  <Style Selector="Expander.mud-expander /template/ ToggleButton">
    <Setter Property="Background" Value="{StaticResource MudBrushStone}" />
    <Setter Property="Foreground" Value="{StaticResource MudBrushGold}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Padding" Value="10,7" />
  </Style>

</Styles>
